@model IEnumerable<OnlinCoursePlatform.Dtos.InstructorCourseDto>

@{
    ViewData["Title"] = "My Courses";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">My Courses</h2>

        <a asp-controller="Courses" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create Course
        </a>
    </div>

    <div class="row g-4">

        @foreach (var course in Model)
        {
            <div class="col-lg-4 col-md-6">

                <div class="card course-card shadow-sm border-0">

                    <img src="@course.ImageUrl"
                         class="card-img-top course-image"
                         alt="@course.Title">

                    <div class="card-body">

                        <h5 class="card-title fw-bold">@course.Title</h5>

                        <span class="badge bg-info text-dark mb-2">
                            @course.CategoryName
                        </span>

                        <p class="mb-1">
                            <i class="bi bi-people"></i>
                            @course.EnrollmentsCount Students
                        </p>

                        <p class="mb-2">
                            <strong>$@course.Price</strong>
                        </p>

                        <span class="badge @(course.Status == "Published" ? "bg-success" : "bg-secondary")">
                            @course.Status
                        </span>

                        <div class="d-flex justify-content-between mt-3 flex-wrap gap-2">

                            <a asp-controller="Lessons"
                               asp-action="ManageContent"
                               asp-route-courseId="@course.Id"
                               class="btn btn-sm btn-success flex-grow-1">
                                <i class="bi bi-journal-plus"></i> Manage Curriculum
                            </a>

                            <div class="w-100 d-flex justify-content-between mt-2">
                                <a asp-controller="Courses"
                                   asp-action="Edit"
                                   asp-route-id="@course.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit Course Info
                                </a>

                                <a asp-controller="Courses"
                                   asp-action="Details"
                                   asp-route-id="@course.Id"
                                   class="btn btn-sm btn-outline-dark">
                                    View Page
                                </a>

                                <form asp-controller="Courses" asp-action="Delete" asp-route-id="@course.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to completely delete this course and all its contents? This cannot be undone.');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </button>
                                </form>
                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>