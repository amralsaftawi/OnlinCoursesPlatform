@model OnlineCoursesPlatform.ViewModels.InstructorPublicProfileViewModel

@{
    ViewData["Title"] = "Instructor Profile";
    var profileImage = string.IsNullOrWhiteSpace(Model.ProfilePicture)
        ? "/images/profiles/default-avatar.png"
        : $"/images/profiles/{Model.ProfilePicture}";
}

<section class="page-hero mb-4">
    <div class="row align-items-center g-4">
        <div class="col-md-8">
            <span class="eyebrow mb-3"><i class="fa-solid fa-chalkboard-user"></i>Instructor Profile</span>
            <h1 class="section-title mb-2">@Model.InstructorName</h1>
            <p class="section-subtitle mb-0">Browse this instructor's published courses and explore their teaching catalog.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <img src="@profileImage" class="rounded-circle shadow-sm border border-3 border-white" width="120" height="120" style="object-fit: cover;" alt="@Model.InstructorName" />
        </div>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="metric-card p-4 h-100">
            <div class="text-muted small mb-2">Published Courses</div>
            <div class="display-6 fw-bold">@Model.TotalCourses</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="metric-card p-4 h-100">
            <div class="text-muted small mb-2">Students Reached</div>
            <div class="display-6 fw-bold">@Model.TotalStudents</div>
        </div>
    </div>
</section>

<section class="row g-4">
    @if (!Model.Courses.Any())
    {
        <div class="col-12">
            <div class="empty-state">
                <i class="fa-regular fa-folder-open fs-1 text-muted mb-3"></i>
                <h4 class="fw-bold">No published courses yet</h4>
                <p class="text-muted">This instructor does not have approved public courses at the moment.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var course in Model.Courses)
        {
            <div class="col-md-6 col-xl-4">
                <div class="course-card h-100 overflow-hidden position-relative" onclick="window.location='@Url.Action("Details", "Courses", new { id = course.Id })'" role="link" tabindex="0" onkeydown="if(event.key==='Enter' || event.key===' '){ window.location='@Url.Action("Details", "Courses", new { id = course.Id })'; }" style="cursor:pointer;">
                    <div class="position-relative">
                        <img src="@(string.IsNullOrWhiteSpace(course.ImageUrl) ? "/images/default-course.jpg" : course.ImageUrl)" class="w-100" style="height: 220px; object-fit: cover;" alt="@course.Title" />
                        <span class="soft-badge position-absolute top-0 start-0 m-3">@course.CategoryName</span>
                    </div>
                    <div class="p-4 d-flex flex-column h-100">
                        <h5 class="fw-bold line-clamp-2">@course.Title</h5>
                        <p class="text-muted line-clamp-2 flex-grow-1">@course.Description</p>
                        <div class="metric-card p-3 mt-3">
                            <div class="d-flex justify-content-between align-items-center gap-3">
                                <div class="fw-bold fs-5 text-primary">@course.CurrencySymbol@course.Price</div>
                                <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="btn btn-app-primary" onclick="event.stopPropagation();">View Course</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</section>
