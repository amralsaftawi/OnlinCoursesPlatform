@model OnlinCoursePlatform.Dtos.InstructorStatsDto

@{
    ViewData["Title"] = "Instructor Overview";
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <span class="eyebrow mb-3"><i class="fa-solid fa-chalkboard-user"></i>Instructor Hub</span>
            <h1 class="section-title mb-2">Track your teaching performance.</h1>
            <p class="section-subtitle mb-0">Follow course growth, student reach, and revenue from a cleaner workspace.</p>
        </div>
        <a asp-action="MyCourses" class="btn btn-app-primary">
            <i class="fa-solid fa-book me-2"></i>Manage My Courses
        </a>
    </div>
</section>

<section class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="dashboard-card p-4 h-100">
            <div class="soft-badge mb-3">Courses</div>
            <div class="metric-value">@Model.TotalCourses</div>
            <p class="text-muted mb-0 mt-2">Courses you are currently responsible for.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card p-4 h-100">
            <div class="soft-badge mb-3">Students</div>
            <div class="metric-value">@Model.TotalStudents.ToString("N0")</div>
            <p class="text-muted mb-0 mt-2">Learners enrolled in your content.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card p-4 h-100">
            <div class="soft-badge mb-3">Revenue</div>
            <div class="metric-value">$@Model.TotalRevenue.ToString("N2")</div>
            <p class="text-muted mb-0 mt-2">Estimated instructor earnings so far.</p>
        </div>
    </div>
</section>

<section class="content-panel p-4">
    <h4 class="fw-bold mb-2">Next best actions</h4>
    <p class="text-muted mb-4">Use the instructor-only tools below to keep your content moving.</p>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="quick-link-card p-3 h-100">
                <div class="fw-bold mb-2">Create a new course</div>
                <p class="text-muted small">Start building your next learning path.</p>
                <a asp-controller="Courses" asp-action="Create" class="btn btn-sm btn-app-primary">Create Course</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="quick-link-card p-3 h-100">
                <div class="fw-bold mb-2">Manage curriculum</div>
                <p class="text-muted small">Update lessons, sections, and publishing state.</p>
                <a asp-action="MyCourses" class="btn btn-sm btn-app-primary">Open My Courses</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="quick-link-card p-3 h-100">
                <div class="fw-bold mb-2">Review your catalog</div>
                <p class="text-muted small">Check how each course is presented to learners.</p>
                <a asp-controller="Courses" asp-action="Index" class="btn btn-sm btn-app-primary">Browse Catalog</a>
            </div>
        </div>
    </div>
</section>
