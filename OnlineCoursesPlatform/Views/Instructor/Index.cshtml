@model OnlinCoursePlatform.Dtos.InstructorStatsDto

@{
    ViewData["Title"] = "Instructor Overview";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
    .stat-card {
        border: none;
        border-radius: 15px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: #fff;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }
    .icon-shape {
        width: 48px;
        height: 48px;
        background-position: center;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .bg-gradient-primary { background: linear-gradient(87deg, #5e72e4 0, #825ee4 100%); }
    .bg-gradient-success { background: linear-gradient(87deg, #2dce89 0, #2dcebe 100%); }
    .bg-gradient-info { background: linear-gradient(87deg, #11cdef 0, #1171ef 100%); }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-0">Instructor Dashboard</h2>
            <p class="text-muted">Monitor your performance and course engagement.</p>
        </div>
        <a asp-action="MyCourses" class="btn btn-dark btn-md shadow-sm rounded-pill px-4">
            <i class="fas fa-list me-2"></i>Manage Courses
        </a>
    </div>

    <div class="row">
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card stat-card shadow-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <span class="text-xs font-weight-bold text-uppercase text-muted mb-1 d-block">Total Courses</span>
                            <span class="h2 font-weight-bold mb-0">@Model.TotalCourses</span>
                        </div>
                        <div class="col-auto">
                            <div class="icon-shape bg-gradient-primary text-white shadow">
                                <i class="fas fa-book-open"></i>
                            </div>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 text-sm">
                        <span class="text-success mr-2"><i class="fa fa-arrow-up"></i> 12%</span>
                        <span class="text-nowrap text-muted">Since last month</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card stat-card shadow-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <span class="text-xs font-weight-bold text-uppercase text-muted mb-1 d-block">Active Students</span>
                            <span class="h2 font-weight-bold mb-0">@Model.TotalStudents.ToString("N0")</span>
                        </div>
                        <div class="col-auto">
                            <div class="icon-shape bg-gradient-success text-white shadow">
                                <i class="fas fa-users"></i>
                            </div>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 text-sm">
                        <span class="text-success mr-2"><i class="fa fa-arrow-up"></i> 5.4%</span>
                        <span class="text-nowrap text-muted">New enrollments</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card stat-card shadow-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <span class="text-xs font-weight-bold text-uppercase text-muted mb-1 d-block">Net Earnings</span>
                            <span class="h2 font-weight-bold mb-0">$@Model.TotalRevenue.ToString("N2")</span>
                        </div>
                        <div class="col-auto">
                            <div class="icon-shape bg-gradient-info text-white shadow">
                                <i class="fas fa-wallet"></i>
                            </div>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 text-sm">
                        <span class="text-primary mr-2">EGP Equivalent:</span>
                        <span class="text-nowrap text-muted">@(Model.TotalRevenue * 50) EGP</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-3 p-5 text-center bg-white">
                <div class="text-muted">
                    <i class="fas fa-chart-line fa-3x mb-3 text-light"></i>
                    <h5>Sales Analytics & Activity Tracking</h5>
                    <p>Integrate <strong>Chart.js</strong> here for a real production feel.</p>
                </div>
            </div>
        </div>
    </div>
</div>