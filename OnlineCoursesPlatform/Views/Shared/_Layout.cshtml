@using Microsoft.AspNetCore.Identity
@inject UserManager<OnlineCoursesPlatform.Models.User> userManager

@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var currentUser = isAuthenticated ? await userManager.GetUserAsync(User) : null;
    var currentRoles = currentUser != null ? await userManager.GetRolesAsync(currentUser) : Array.Empty<string>();
    var isAdmin = currentRoles.Contains("Admin");
    var isInstructor = currentRoles.Contains("Instructor");
    var isStudent = currentRoles.Contains("Student");
    var profileImage = string.IsNullOrWhiteSpace(currentUser?.ProfilePicture)
        ? Url.Content("~/images/profiles/default-avatar.png")
        : Url.Content($"~/images/profiles/{currentUser.ProfilePicture}");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduMaster</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <nav class="navbar navbar-expand-lg topbar navbar-dark sticky-top">
            <div class="container py-2">
                <a class="navbar-brand d-flex align-items-center gap-3 fw-bold" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">
                        <i class="fa-solid fa-graduation-cap"></i>
                    </span>
                    <span>EduMaster</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto align-items-lg-center gap-lg-2 mt-3 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="Courses" asp-action="Index">Browse Courses</a>
                        </li>

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill nav-pill-accent" asp-controller="Admin" asp-action="Index">
                                    <i class="fa-solid fa-shield-halved me-2"></i>Admin Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Admin" asp-action="Users">Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Admin" asp-action="Courses">Course Reviews</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Admin" asp-action="Categories">Categories</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Admin" asp-action="Currencies">Currencies</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Admin" asp-action="Tags">Tags</a>
                            </li>
                        }
                        @if (isInstructor && !isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill nav-pill-accent" asp-controller="Instructor" asp-action="Index">
                                    <i class="fa-solid fa-chalkboard-user me-2"></i>Instructor Hub
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Courses" asp-action="Create">
                                    <i class="fa-solid fa-circle-plus me-2"></i>Create Course
                                </a>
                            </li>
                        }
                        @if (isStudent && !isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill nav-pill-accent" asp-controller="Enrollment" asp-action="GetMyEnrolledCourses">
                                    <i class="fa-solid fa-play-circle me-2"></i>My Learning
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2 mt-3 mt-lg-0">
                        @if (isAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="@profileImage" alt="Profile" class="rounded-circle nav-avatar" />
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-app" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fa-regular fa-user me-2"></i>My Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="EditProfile"><i class="fa-solid fa-gear me-2"></i>Edit Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="fa-solid fa-key me-2"></i>Change Password</a></li>

                                    @if (isAdmin)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="fa-solid fa-chart-line me-2"></i>Admin Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="fa-solid fa-users-gear me-2"></i>Users And Roles</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Courses"><i class="fa-solid fa-clipboard-check me-2"></i>Course Reviews</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Categories"><i class="fa-solid fa-layer-group me-2"></i>Categories</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Currencies"><i class="fa-solid fa-money-bill-wave me-2"></i>Currencies</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Tags"><i class="fa-solid fa-tags me-2"></i>Tags</a></li>
                                    }
                                    @if (isStudent && !isAdmin)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Enrollment" asp-action="GetMyEnrolledCourses"><i class="fa-solid fa-book-open-reader me-2"></i>My Learning</a></li>
                                    }

                                    @if (isInstructor && !isAdmin)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Instructor" asp-action="MyCourses"><i class="fa-solid fa-book me-2"></i>My Courses</a></li>
                                    }

                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger border-0 bg-transparent w-100 text-start">
                                                <i class="fa-solid fa-right-from-bracket me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-app-primary" asp-controller="Account" asp-action="Register">Join EduMaster</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <main class="main-shell">
            <div class="container">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-app mb-4">@TempData["Success"]</div>
                }

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-app mb-4">@TempData["SuccessMessage"]</div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-app mb-4">@TempData["Error"]</div>
                }

                @RenderBody()
            </div>
        </main>

        <footer class="footer-shell py-5">
            <div class="container">
                <div class="row g-4 align-items-start">
                    <div class="col-lg-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="brand-mark">
                                <i class="fa-solid fa-graduation-cap"></i>
                            </span>
                            <div>
                                <h5 class="mb-0 text-white">EduMaster</h5>
                                <small class="text-white-50">Learn deeply. Teach boldly.</small>
                            </div>
                        </div>
                        <p class="mb-0 text-white-50">A cleaner learning platform for students, instructors, and admins with role-specific workspaces that keep every journey focused.</p>
                    </div>

                    <div class="col-sm-6 col-lg-2">
                        <h6 class="text-white mb-3">Explore</h6>
                        <div class="d-flex flex-column gap-2">
                            <a asp-controller="Home" asp-action="Index">Home</a>
                            <a asp-controller="Courses" asp-action="Index">Courses</a>
                        </div>
                    </div>

                    <div class="col-sm-6 col-lg-3">
                        <h6 class="text-white mb-3">Workspace</h6>
                        <div class="d-flex flex-column gap-2">
                            @if (isAdmin)
                            {
                                <a asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                                <a asp-controller="Admin" asp-action="Users">Users And Roles</a>
                                <a asp-controller="Admin" asp-action="Courses">Course Reviews</a>
                                <a asp-controller="Admin" asp-action="Categories">Categories</a>
                                <a asp-controller="Admin" asp-action="Currencies">Currencies</a>
                                <a asp-controller="Admin" asp-action="Tags">Tags</a>
                            }
                            @if (isStudent && !isAdmin)
                            {
                                <a asp-controller="Enrollment" asp-action="GetMyEnrolledCourses">My Learning</a>
                            }
                            @if (isInstructor && !isAdmin)
                            {
                                <a asp-controller="Instructor" asp-action="Index">Instructor Hub</a>
                            }
                            @if (!isAuthenticated)
                            {
                                <a asp-controller="Account" asp-action="Register">Create Account</a>
                                <a asp-controller="Account" asp-action="Login">Login</a>
                            }
                        </div>
                    </div>

                    <div class="col-lg-3 text-lg-end">
                        <h6 class="text-white mb-3">Built For Roles</h6>
                        <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                            <span class="soft-badge bg-transparent text-white border-secondary">Students</span>
                            <span class="soft-badge bg-transparent text-white border-secondary">Instructors</span>
                            <span class="soft-badge bg-transparent text-white border-secondary">Admins</span>
                        </div>
                    </div>
                </div>

                <hr class="border-secondary my-4" />
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 text-white-50 small">
                    <span>© 2026 EduMaster. Focused learning for every role.</span>
                    <span>Online Courses Platform</span>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
