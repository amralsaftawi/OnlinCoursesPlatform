<div class="modal fade" id="addQuizLessonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-controller="Lessons" asp-action="AddLesson" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Add Quiz Lesson</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />
                    <input type="hidden" name="SectionId" id="quizSectionIdInput" />
                    <input type="hidden" name="Type" value="@((int)LessonType.Quiz)" />

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Quiz Title</label>
                            <input type="text" class="form-control" name="Title" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Quiz Type</label>
                            <select class="form-select" name="QuizMode" id="quizModeSelect" required>
                                <option value="@((int)QuizQuestionType.TrueFalse)">True / False</option>
                                <option value="@((int)QuizQuestionType.MultipleChoice)">Choose</option>
                                <option value="@((int)QuizQuestionType.Written)">Written</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Question Prompt</label>
                            <textarea class="form-control" rows="3" name="QuizPrompt" required placeholder="Ask the learner one clear question."></textarea>
                        </div>
                    </div>

                    <div id="quizTrueFalseFields" class="mt-4">
                        <label class="form-label fw-semibold">Correct Answer</label>
                        <select class="form-select" name="QuizCorrectTrueFalse">
                            <option value="true">True</option>
                            <option value="false">False</option>
                        </select>
                    </div>

                    <div id="quizMultipleChoiceFields" class="mt-4 d-none">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Option A</label>
                                <input type="text" class="form-control" name="QuizOptionA" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Option B</label>
                                <input type="text" class="form-control" name="QuizOptionB" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Option C</label>
                                <input type="text" class="form-control" name="QuizOptionC" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Option D</label>
                                <input type="text" class="form-control" name="QuizOptionD" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Correct Option</label>
                                <select class="form-select" name="QuizCorrectOption">
                                    <option value="">Select</option>
                                    <option value="1">Option A</option>
                                    <option value="2">Option B</option>
                                    <option value="3">Option C</option>
                                    <option value="4">Option D</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div id="quizWrittenFields" class="mt-4 d-none">
                        <label class="form-label fw-semibold">Reference Answer</label>
                        <textarea class="form-control" rows="4" name="QuizReferenceAnswer" placeholder="Optional guidance shown after the learner submits a written response."></textarea>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Duration (Minutes)</label>
                            <input type="number" class="form-control" name="Duration" required min="1" value="5" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsFree" value="true" id="isFreeQuiz" />
                                <label class="form-check-label" for="isFreeQuiz">Free Preview</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-app-secondary-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-app-primary">Save Quiz Lesson</button>
                </div>
            </form>
        </div>
    </div>
</div>

