            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function assignSectionId(selector, inputId) {
            document.querySelectorAll(selector).forEach(button => {
                button.addEventListener('click', function () {
                    document.getElementById(inputId).value = this.getAttribute('data-sectionid');
                });
            });
        }

        function configureQuizFields(modeValue, trueFalseContainer, multipleChoiceContainer, writtenContainer) {
            const mode = parseInt(modeValue, 10);
            trueFalseContainer.classList.toggle('d-none', mode !== @((int)QuizQuestionType.TrueFalse));
            multipleChoiceContainer.classList.toggle('d-none', mode !== @((int)QuizQuestionType.MultipleChoice));
            writtenContainer.classList.toggle('d-none', mode !== @((int)QuizQuestionType.Written));
        }

        assignSectionId('.launch-video-modal', 'videoSectionIdInput');
        assignSectionId('.launch-pdf-modal', 'pdfSectionIdInput');
        assignSectionId('.launch-article-modal', 'articleSectionIdInput');
        assignSectionId('.launch-quiz-modal', 'quizSectionIdInput');

        const quizModeSelect = document.getElementById('quizModeSelect');
        const quizTrueFalseFields = document.getElementById('quizTrueFalseFields');
        const quizMultipleChoiceFields = document.getElementById('quizMultipleChoiceFields');
        const quizWrittenFields = document.getElementById('quizWrittenFields');

        quizModeSelect.addEventListener('change', function () {
            configureQuizFields(this.value, quizTrueFalseFields, quizMultipleChoiceFields, quizWrittenFields);
        });
        configureQuizFields(quizModeSelect.value, quizTrueFalseFields, quizMultipleChoiceFields, quizWrittenFields);

        const editLessonModal = new bootstrap.Modal(document.getElementById('editLessonModal'));
        const editLessonType = document.getElementById('editLessonType');
        const editContentUrlWrapper = document.getElementById('editContentUrlWrapper');
        const editContentLabel = document.getElementById('editContentLabel');
        const editContentHelp = document.getElementById('editContentHelp');
        const editContentUrl = document.getElementById('editContentUrl');
        const editPdfFileWrapper = document.getElementById('editPdfFileWrapper');
        const editArticleFileWrapper = document.getElementById('editArticleFileWrapper');
        const editQuizFields = document.getElementById('editQuizFields');
        const editQuizMode = document.getElementById('editQuizMode');
        const editQuizTrueFalseFields = document.getElementById('editQuizTrueFalseFields');
        const editQuizMultipleChoiceFields = document.getElementById('editQuizMultipleChoiceFields');
        const editQuizWrittenFields = document.getElementById('editQuizWrittenFields');

        function configureEditTypeFields() {
            const lessonType = parseInt(editLessonType.value, 10);
            const isVideo = lessonType === @((int)LessonType.Video);
            const isPdf = lessonType === @((int)LessonType.PDF);
            const isArticle = lessonType === @((int)LessonType.Article);
            const isQuiz = lessonType === @((int)LessonType.Quiz);

            editContentUrlWrapper.classList.toggle('d-none', isQuiz);
            editPdfFileWrapper.classList.toggle('d-none', !isPdf);
            editArticleFileWrapper.classList.toggle('d-none', !isArticle);
            editQuizFields.classList.toggle('d-none', !isQuiz);

            if (isVideo) {
                editContentLabel.textContent = 'Video URL';
                editContentHelp.textContent = 'Paste a direct video URL, YouTube link, or embeddable player URL.';
                editContentUrl.readOnly = false;
                editContentUrl.placeholder = 'https://example.com/video.mp4';
            } else if (isPdf) {
                editContentLabel.textContent = 'PDF Source';
                editContentHelp.textContent = 'Keep the current PDF path, paste a new direct PDF URL, or upload a replacement PDF below.';
                editContentUrl.readOnly = false;
                editContentUrl.placeholder = 'https://example.com/file.pdf or /uploads/pdfs/your-file.pdf';
            } else if (isArticle) {
                editContentLabel.textContent = 'Current Article Source';
                editContentHelp.textContent = 'Keep the current article text file path or upload a replacement `.txt` file below.';
                editContentUrl.readOnly = true;
                editContentUrl.placeholder = '/uploads/articles/current-article.txt';
            }

            if (isQuiz) {
                configureQuizFields(editQuizMode.value, editQuizTrueFalseFields, editQuizMultipleChoiceFields, editQuizWrittenFields);
            }
        }

        editLessonType.addEventListener('change', configureEditTypeFields);
        editQuizMode.addEventListener('change', function () {
            configureQuizFields(this.value, editQuizTrueFalseFields, editQuizMultipleChoiceFields, editQuizWrittenFields);
        });

        document.querySelectorAll('.edit-lesson-btn').forEach(button => {
            button.addEventListener('click', function () {
                const lessonId = this.getAttribute('data-lessonid');

                fetch(`/Lessons/GetLessonForEdit?lessonId=${lessonId}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Failed to load lesson.');
                        }

                        return response.json();
                    })
                    .then(data => {
                        document.getElementById('editLessonIdInput').value = data.lessonId;
                        document.getElementById('editSectionIdInput').value = data.sectionId;
                        document.getElementById('editLessonTitle').value = data.title;
                        document.getElementById('editLessonType').value = data.type;
                        document.getElementById('editContentUrl').value = data.type === @((int)LessonType.Quiz) ? '' : (data.contentUrl || '');
                        document.getElementById('editDuration').value = data.duration;
                        document.getElementById('editIsFree').checked = data.isFree;

                        document.getElementById('editQuizMode').value = data.quizQuestionType ?? @((int)QuizQuestionType.TrueFalse);
                        document.getElementById('editQuizPrompt').value = data.quizPrompt || '';
                        document.getElementById('editQuizOptionA').value = data.quizOptionA || '';
                        document.getElementById('editQuizOptionB').value = data.quizOptionB || '';
                        document.getElementById('editQuizOptionC').value = data.quizOptionC || '';
                        document.getElementById('editQuizOptionD').value = data.quizOptionD || '';
                        document.getElementById('editQuizCorrectOption').value = data.quizCorrectOption || '';
                        document.getElementById('editQuizCorrectTrueFalse').value = data.quizCorrectTrueFalse === null ? '' : data.quizCorrectTrueFalse.toString();
                        document.getElementById('editQuizReferenceAnswer').value = data.quizReferenceAnswer || '';
                        document.getElementById('editPdfFileInput').value = '';
                        document.getElementById('editArticleFileInput').value = '';

                        configureEditTypeFields();
                        editLessonModal.show();
                    })
                    .catch(() => alert('Unable to fetch lesson information.'));
            });
        });
    </script>
}
