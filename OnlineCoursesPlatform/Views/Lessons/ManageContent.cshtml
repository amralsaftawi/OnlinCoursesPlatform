@model OnlineCoursesPlatform.ViewModels.ManageCourseContentViewModel
@using OnlineCoursesPlatform.Models.Enums

@functions {
    private static (string Label, string Icon) DescribeLessonType(LessonType type)
    {
        return type switch
        {
            LessonType.Video => ("Video", "fa-circle-play"),
            LessonType.PDF => ("PDF", "fa-file-pdf"),
            LessonType.Article => ("Article TXT", "fa-file-lines"),
            LessonType.Quiz => ("Quiz", "fa-circle-question"),
            _ => ("Lesson", "fa-book-open")
        };
    }
}

@{
    ViewData["Title"] = "Manage Course Content";
}

<section class="page-hero mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <span class="eyebrow mb-3"><i class="fa-solid fa-diagram-project"></i>Curriculum Builder</span>
            <h1 class="section-title mb-2">@Model.CourseTitle</h1>
            <p class="section-subtitle mb-0">Build your course with sections, videos, PDFs, text articles, and quizzes while the total duration stays calculated automatically.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Instructor" asp-action="MyCourses" class="btn btn-app-secondary-dark">Back to Courses</a>
            <button type="button" class="btn btn-app-primary" data-bs-toggle="modal" data-bs-target="#addSectionModal">Add Section</button>
        </div>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="metric-card p-4 h-100">
            <div class="text-muted small mb-2">Sections</div>
            <div class="display-6 fw-bold">@Model.SectionCount</div>
            <div class="small text-muted">Structure the course into clear stages.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card p-4 h-100">
            <div class="text-muted small mb-2">Lessons</div>
            <div class="display-6 fw-bold">@Model.LessonCount</div>
            <div class="small text-muted">Video, PDF, article, and quiz lessons.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card p-4 h-100">
            <div class="text-muted small mb-2">Total Duration</div>
            <div class="display-6 fw-bold">@Model.TotalDuration <span class="fs-6">min</span></div>
            <div class="small text-muted">Updated automatically from lesson durations.</div>
        </div>
    </div>
</section>

@if (!Model.Sections.Any())
{
    <div class="empty-state">
        <i class="fa-regular fa-folder-open fs-1 text-muted mb-3"></i>
        <h4 class="fw-bold">No curriculum content yet</h4>
        <p class="text-muted">Start with a section, then add the lesson format that fits best.</p>
        <button type="button" class="btn btn-app-primary mt-2" data-bs-toggle="modal" data-bs-target="#addSectionModal">Add Section</button>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        @foreach (var courseSection in Model.Sections)
        {
            <section class="content-panel p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <div class="small text-muted text-uppercase mb-2">Section @courseSection.OrderIndex</div>
                        <h4 class="fw-bold mb-1">@courseSection.Title</h4>
                        <div class="small text-muted">@(courseSection.Lessons?.Count ?? 0) lesson@(courseSection.Lessons?.Count == 1 ? string.Empty : "s") in this section.</div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-app-primary launch-video-modal" data-bs-toggle="modal" data-bs-target="#addVideoLessonModal" data-sectionid="@courseSection.Id">Add Video</button>
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill launch-pdf-modal" data-bs-toggle="modal" data-bs-target="#addPdfLessonModal" data-sectionid="@courseSection.Id">Add PDF</button>
                        <button type="button" class="btn btn-sm btn-outline-info rounded-pill launch-article-modal" data-bs-toggle="modal" data-bs-target="#addArticleLessonModal" data-sectionid="@courseSection.Id">Add Article TXT</button>
                        <button type="button" class="btn btn-sm btn-outline-warning rounded-pill launch-quiz-modal" data-bs-toggle="modal" data-bs-target="#addQuizLessonModal" data-sectionid="@courseSection.Id">Add Quiz</button>
                    </div>
                </div>

                @if (!(courseSection.Lessons?.Any() ?? false))
                {
                    <div class="empty-state py-4">
                        <p class="text-muted mb-0">This section is ready for its first lesson.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var lesson in courseSection.Lessons.OrderBy(lesson => lesson.OrderIndex))
                        {
                            var meta = DescribeLessonType(lesson.Type);

                            <article class="metric-card p-3">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                                    <div class="d-flex gap-3">
                                        <div class="soft-badge">
                                            <i class="fa-solid @meta.Icon"></i>@meta.Label
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@lesson.OrderIndex. @lesson.Title</div>
                                            <div class="small text-muted mt-1">@lesson.Duration min &bull; @(lesson.IsFree ? "Free preview" : "Enrolled students only")</div>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2 flex-wrap">
                                        <button type="button" class="btn btn-sm btn-outline-warning rounded-pill edit-lesson-btn" data-lessonid="@lesson.Id">Edit</button>
                                        <a asp-controller="Learning" asp-action="Details" asp-route-id="@lesson.Id" class="btn btn-sm btn-outline-info rounded-pill">Preview</a>
                                        <form asp-controller="Lessons" asp-action="DeleteLesson" method="post" onsubmit="return confirm('Are you sure you want to delete this lesson?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="lessonId" value="@lesson.Id" />
                                            <input type="hidden" name="courseId" value="@Model.CourseId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }
    </div>
}

<div class="modal fade" id="addSectionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Lessons" asp-action="AddSection" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Add New Section</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />
                    <label class="form-label fw-semibold">Section Title</label>
                    <input type="text" class="form-control" name="Title" required />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-app-secondary-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-app-primary">Save Section</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addVideoLessonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Lessons" asp-action="AddLesson" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Add Video Lesson</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />
                    <input type="hidden" name="SectionId" id="videoSectionIdInput" />
                    <input type="hidden" name="Type" value="@((int)LessonType.Video)" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Video Title</label>
                        <input type="text" class="form-control" name="Title" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Video URL</label>
                        <input type="url" class="form-control" name="ContentUrl" required placeholder="https://example.com/video.mp4 or https://youtube.com/watch?v=..." />
                        <div class="form-text">Paste a direct video file URL, YouTube link, or embeddable player URL.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Duration (Minutes)</label>
                            <input type="number" class="form-control" name="Duration" required min="1" value="5" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsFree" value="true" id="isFreeVideo" />
                                <label class="form-check-label" for="isFreeVideo">Free Preview</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-app-secondary-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-app-primary">Save Video Lesson</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addPdfLessonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Lessons" asp-action="AddLesson" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Add PDF Lesson</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />
                    <input type="hidden" name="SectionId" id="pdfSectionIdInput" />
                    <input type="hidden" name="Type" value="@((int)LessonType.PDF)" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">PDF Lesson Title</label>
                        <input type="text" class="form-control" name="Title" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Direct PDF URL</label>
                        <input type="url" class="form-control" name="ContentUrl" placeholder="https://example.com/ebook.pdf" />
                        <div class="form-text">Use a direct PDF link, or leave it empty and upload the file locally below.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Upload PDF</label>
                        <input type="file" class="form-control" name="PdfFile" accept=".pdf,application/pdf" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Duration (Minutes)</label>
                            <input type="number" class="form-control" name="Duration" required min="1" value="5" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsFree" value="true" id="isFreePdf" />
                                <label class="form-check-label" for="isFreePdf">Free Preview</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-app-secondary-dark" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-app-primary">Save PDF Lesson</button>
                </div>
            </form>
        </div>
    </div>
</div>

