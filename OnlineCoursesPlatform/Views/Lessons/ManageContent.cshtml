@model OnlineCoursesPlatform.ViewModels.ManageCourseContentViewModel

@{
    ViewData["Title"] = "Manage Course Content";
    // Assuming you have an Instructor Layout, otherwise this falls back to _Layout
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Content: <span class="text-primary">@Model.CourseTitle</span></h2>
        <div>
            <a asp-controller="Instructor" asp-action="MyCourses" class="btn btn-outline-secondary me-2">Back to Courses</a>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addSectionModal">
                <i class="bi bi-plus-circle"></i> Add Section
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Sections.Any())
    {
        <div class="text-center p-5 bg-light rounded shadow-sm border">
            <h4 class="text-muted">No Curriculum Content Yet</h4>
            <p>Start building your course by adding your first section.</p>
            <button type="button" class="btn btn-primary mt-2" data-bs-toggle="modal" data-bs-target="#addSectionModal">
                Add Section
            </button>
        </div>
    }
    else
    {
        <div class="accordion" id="curriculumAccordion">
            @foreach (var courseSection in Model.Sections)
            {
                <div class="accordion-item mb-3 shadow-sm border-0 rounded">
                    <h2 class="accordion-header" id="heading-@courseSection.Id">
                        <button class="accordion-button bg-light rounded fw-bold text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@courseSection.Id" aria-expanded="true" aria-controls="collapse-@courseSection.Id">
                            Section @courseSection.OrderIndex: @courseSection.Title
                        </button>
                    </h2>
                    <div id="collapse-@courseSection.Id" class="accordion-collapse collapse show" aria-labelledby="heading-@courseSection.Id">
                        <div class="accordion-body">
                            
                            @if (!courseSection.Lessons.Any())
                            {
                                <p class="text-muted small mb-3">No lessons in this section. Add a video or article below.</p>
                            }
                            else
                            {
                                <ul class="list-group mb-3">
                                    @foreach (var lesson in courseSection.Lessons.OrderBy(l => l.OrderIndex))
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                @if (lesson.Type == OnlineCoursesPlatform.Models.Enums.LessonType.Video)
                                                {
                                                    <i class="bi bi-play-circle-fill text-primary me-2"></i>
                                                }
                                                else if (lesson.Type == OnlineCoursesPlatform.Models.Enums.LessonType.Article)
                                                {
                                                    <i class="bi bi-file-text-fill text-success me-2"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-question-circle-fill text-secondary me-2"></i>
                                                }
                                                <span class="fw-semibold">@lesson.OrderIndex. @lesson.Title</span>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="badge bg-secondary me-2">@lesson.Duration min</span>
                                                <button type="button" class="btn btn-sm btn-outline-warning me-2 edit-lesson-btn" data-lessonid="@lesson.Id">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </button>
                                                <a href="@lesson.ContentUrl" target="_blank" class="btn btn-sm btn-outline-info me-2">View</a>
                                                
                                                <form asp-controller="Lessons" asp-action="DeleteLesson" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this lesson? This cannot be undone.');">
                                                    <input type="hidden" name="lessonId" value="@lesson.Id" />
                                                    <input type="hidden" name="courseId" value="@Model.CourseId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }

                            <!-- Add Lesson Button (Triggers Modal and passes SectionId) -->
                            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addLessonModal" data-sectionid="@courseSection.Id">
                                <i class="bi bi-plus"></i> Add Lesson
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Add Section Modal -->
<div class="modal fade" id="addSectionModal" tabindex="-1" aria-labelledby="addSectionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Lessons" asp-action="AddSection" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="addSectionModalLabel">Add New Section</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />
                    <div class="mb-3">
                        <label for="sectionTitle" class="form-label">Section Title</label>
                        <input type="text" class="form-control" id="sectionTitle" name="Title" required placeholder="e.g. Introduction to Programming">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Section</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Lesson Modal -->
<div class="modal fade" id="addLessonModal" tabindex="-1" aria-labelledby="addLessonModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Lessons" asp-action="AddLesson" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="addLessonModalLabel">Add New Lesson</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />
                    <input type="hidden" name="SectionId" id="modalSectionIdInput" value="" />
                    
                    <div class="mb-3">
                        <label for="lessonTitle" class="form-label">Lesson Title</label>
                        <input type="text" class="form-control" id="lessonTitle" name="Title" required>
                    </div>

                    <div class="mb-3">
                        <label for="lessonType" class="form-label">Lesson Type</label>
                        <select class="form-select" id="lessonType" name="Type" required>
                            <option value="0">Video</option>
                            <option value="1">Article</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="contentUrl" class="form-label">Content URL (e.g. YouTube Link)</label>
                        <input type="url" class="form-control" id="contentUrl" name="ContentUrl" required placeholder="https://youtube.com/...">
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="duration" class="form-label">Duration (Minutes)</label>
                            <input type="number" class="form-control" id="duration" name="Duration" required min="1" value="5">
                        </div>
                        <div class="col-md-6 d-flex align-items-end mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isFree" name="IsFree" value="true">
                                <label class="form-check-label" for="isFree">
                                    Free Preview
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Lesson</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Lesson Modal -->
<div class="modal fade" id="editLessonModal" tabindex="-1" aria-labelledby="editLessonModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Lessons" asp-action="EditLesson" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="editLessonModalLabel">Edit Lesson</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CourseId" value="@Model.CourseId" />
                    <input type="hidden" name="SectionId" id="editSectionIdInput" />
                    <input type="hidden" name="LessonId" id="editLessonIdInput" />
                    
                    <div class="mb-3">
                        <label for="editLessonTitle" class="form-label">Lesson Title</label>
                        <input type="text" class="form-control" id="editLessonTitle" name="Title" required>
                    </div>

                    <div class="mb-3">
                        <label for="editLessonType" class="form-label">Lesson Type</label>
                        <select class="form-select" id="editLessonType" name="Type" required>
                            <option value="0">Video</option>
                            <option value="1">Article</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="editContentUrl" class="form-label">Content URL</label>
                        <input type="url" class="form-control" id="editContentUrl" name="ContentUrl" required>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="editDuration" class="form-label">Duration (Minutes)</label>
                            <input type="number" class="form-control" id="editDuration" name="Duration" required min="1">
                        </div>
                        <div class="col-md-6 d-flex align-items-end mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="editIsFree" name="IsFree" value="true">
                                <label class="form-check-label" for="editIsFree">
                                    Free Preview
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Script to pass SectionId into the AddLesson Modal dynamically
        var addLessonModal = document.getElementById('addLessonModal');
        addLessonModal.addEventListener('show.bs.modal', function (event) {
            // Button that triggered the modal
            var button = event.relatedTarget;
            // Extract info from data-bs-* attributes
            var sectionId = button.getAttribute('data-sectionid');
            // Update the modal's hidden input
            var sectionIdInput = addLessonModal.querySelector('#modalSectionIdInput');
            sectionIdInput.value = sectionId;
        });

        // Script to fetch Lesson Data and open Edit Modal
        const editLessonModal = new bootstrap.Modal(document.getElementById('editLessonModal'));
        const editButtons = document.querySelectorAll('.edit-lesson-btn');

        editButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                var lessonId = this.getAttribute('data-lessonid');

                // Instant fetch the backend for current DB details
                fetch(`/Lessons/GetLessonForEdit?lessonId=${lessonId}`)
                .then(response => response.json())
                .then(data => {
                    // Populate fields
                    document.getElementById('editLessonIdInput').value = data.lessonId;
                    document.getElementById('editSectionIdInput').value = data.sectionId;
                    document.getElementById('editLessonTitle').value = data.title;
                    document.getElementById('editLessonType').value = data.type;
                    document.getElementById('editContentUrl').value = data.contentUrl;
                    document.getElementById('editDuration').value = data.duration;
                    
                    document.getElementById('editIsFree').checked = data.isFree;

                    // Trigger the UI opening
                    editLessonModal.show();
                })
                .catch(err => {
                    console.error('Failed to load lesson for editing', err);
                    alert("Unable to fetch lesson information.");
                });
            });
        });
    </script>
}
