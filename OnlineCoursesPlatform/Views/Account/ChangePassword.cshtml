@model OnlinCoursePlatform.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center py-4 py-lg-5">
    <div class="col-xl-8 col-lg-9">
        <div class="auth-shell">
            <div class="row g-0">
                <div class="col-lg-5 auth-banner p-4 p-lg-5 d-flex flex-column justify-content-between">
                    <div>
                        <span class="eyebrow bg-white text-dark mb-3"><i class="fa-solid fa-key"></i>Security</span>
                        <h1 class="fw-bold mb-3">Update your password safely.</h1>
                        <p class="text-white-50 mb-0">Use a new password you have not reused elsewhere to keep the account secure.</p>
                    </div>
                    <div class="soft-badge bg-transparent text-white border-secondary">
                        <i class="fa-solid fa-shield-halved"></i>Your session stays active after a successful change.
                    </div>
                </div>

                <div class="col-lg-7 p-4 p-lg-5">
                    <h2 class="fw-bold mb-2">Change Password</h2>
                    <p class="text-muted mb-4">Enter your current password, then choose the new one.</p>

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold">Current Password</label>
                            <input asp-for="CurrentPassword" class="form-control" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                            <input asp-for="NewPassword" class="form-control" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-semibold">Confirm New Password</label>
                            <input asp-for="ConfirmNewPassword" class="form-control" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-app-primary">Save New Password</button>
                            <a asp-action="Profile" class="btn btn-app-secondary-dark">Back To Profile</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
