@model OnlineCoursesPlatform.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="row justify-content-center py-4 py-lg-5">
    <div class="col-xl-9">
        <div class="auth-shell">
            <div class="row g-0">
                <div class="col-lg-5 auth-banner p-4 p-lg-5 d-flex flex-column justify-content-between">
                    <div>
                        <span class="eyebrow bg-white text-dark mb-3"><i class="fa-solid fa-envelope-open-text"></i>Recovery</span>
                        <h1 class="fw-bold mb-3">Reset access to your account.</h1>
                        <p class="text-white-50 mb-0">Enter the account email and the platform will generate a secure password reset link.</p>
                    </div>
                    <div class="soft-badge bg-transparent text-white border-secondary">
                        <i class="fa-solid fa-link"></i>Until email sending is wired in, the link appears here directly.
                    </div>
                </div>

                <div class="col-lg-7 p-4 p-lg-5">
                    <h2 class="fw-bold mb-2">Forgot Password</h2>
                    <p class="text-muted mb-4">Use the email tied to your platform account.</p>

                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success border-0 rounded-4">@ViewBag.SuccessMessage</div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-app-primary">Generate Reset Link</button>
                            <a asp-action="Login" class="btn btn-app-secondary-dark">Back To Login</a>
                        </div>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.GeneratedResetLink))
                    {
                        <div class="metric-card p-3 mt-4">
                            <div class="fw-semibold mb-2">Reset Link</div>
                            <a href="@Model.GeneratedResetLink" class="text-break">@Model.GeneratedResetLink</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
