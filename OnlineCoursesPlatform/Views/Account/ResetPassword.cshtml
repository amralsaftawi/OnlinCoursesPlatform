@model OnlineCoursesPlatform.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center py-4 py-lg-5">
    <div class="col-xl-8 col-lg-9">
        <div class="auth-shell">
            <div class="row g-0">
                <div class="col-lg-5 auth-banner p-4 p-lg-5 d-flex flex-column justify-content-between">
                    <div>
                        <span class="eyebrow bg-white text-dark mb-3"><i class="fa-solid fa-unlock-keyhole"></i>Reset</span>
                        <h1 class="fw-bold mb-3">Choose a fresh password.</h1>
                        <p class="text-white-50 mb-0">Once saved, you can sign in again with the new password immediately.</p>
                    </div>
                    <div class="soft-badge bg-transparent text-white border-secondary">
                        <i class="fa-solid fa-circle-check"></i>The reset token is carried securely in this form.
                    </div>
                </div>

                <div class="col-lg-7 p-4 p-lg-5">
                    <h2 class="fw-bold mb-2">Reset Password</h2>
                    <p class="text-muted mb-4">Confirm the email and set the new password.</p>

                    <form asp-action="ResetPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input asp-for="Token" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" class="form-control" readonly />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">New Password</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-app-primary">Reset Password</button>
                            <a asp-action="Login" class="btn btn-app-secondary-dark">Back To Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
