@model OnlinCoursePlatform.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Welcome Back";
}

<div class="row justify-content-center py-4 py-lg-5">
    <div class="col-xl-10">
        <div class="auth-shell">
            <div class="row g-0">
                <div class="col-lg-5 auth-banner p-4 p-lg-5 d-flex flex-column justify-content-between">
                    <div>
                        <span class="eyebrow bg-white text-dark mb-3"><i class="fa-solid fa-right-to-bracket"></i>Login</span>
                        <h1 class="fw-bold mb-3">Continue your learning flow.</h1>
                        <p class="text-white-50">Sign in to access the role-specific dashboard that matches your account.</p>
                    </div>
                    <div class="d-flex flex-column gap-3 mt-4">
                        <div class="soft-badge bg-transparent text-white border-secondary"><i class="fa-solid fa-user-graduate"></i>Students resume enrolled courses</div>
                        <div class="soft-badge bg-transparent text-white border-secondary"><i class="fa-solid fa-chalkboard-user"></i>Instructors manage their content</div>
                        <div class="soft-badge bg-transparent text-white border-secondary"><i class="fa-solid fa-shield-halved"></i>Admins review platform activity</div>
                    </div>
                </div>

                <div class="col-lg-7 p-4 p-lg-5">
                    <h2 class="fw-bold mb-2">Log In</h2>
                    <p class="text-muted mb-4">Enter your email and password to continue.</p>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                        </div>

                        <button type="submit" class="btn btn-app-primary w-100">Sign In</button>
                    </form>

                    <p class="text-muted mt-4 mb-0">
                        New to EduMaster?
                        <a asp-action="Register" class="fw-bold text-decoration-none text-primary">Create an account</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
