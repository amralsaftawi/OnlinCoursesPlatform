@using OnlinCoursePlatform.ViewModels
@model EditProfileViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 text-center">
                    <h4 class="fw-bold"><i class="fas fa-user-edit text-primary me-2"></i>Edit Your Profile</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                        <div class="row justify-content-center">
                            <div class="col-12 text-center mb-4">
                                <div class="position-relative d-inline-block">
                                    @* عرض الصورة الحالية من السيرفر *@
                                    <img src="~/images/profiles/@(Model.ExistingImageUrl ?? "default-avatar.png")" 
                                         class="rounded-circle shadow border border-3 border-white" 
                                         width="130" height="130" 
                                         id="previewImg" 
                                         style="object-fit: cover;">
                                    
                                    <label for="imgUpload" class="btn btn-primary position-absolute bottom-0 end-0 rounded-circle shadow-sm p-2">
                                        <i class="fas fa-camera"></i>
                                    </label>
                                    <input type="file" asp-for="ProfileImage" id="imgUpload" hidden accept="image/*" onchange="previewImage(this)">
                                </div>
                                <p class="text-muted small mt-2">Click the camera to update photo</p>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">First Name</label>
                                <input asp-for="FirstName" class="form-control rounded-pill px-3">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Last Name</label>
                                <input asp-for="LastName" class="form-control rounded-pill px-3">
                            </div>
                            <div class="col-12 mb-4">
                                <label class="form-label fw-bold">Brief Bio (Optional)</label>
                                <textarea asp-for="Bio" class="form-control rounded-4" rows="4" placeholder="Tell students about your experience..."></textarea>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-center pt-3">
                            <a asp-action="Profile" class="btn btn-light rounded-pill px-4">Cancel</a>
                            <a asp-action="ChangePassword" class="btn btn-outline-dark rounded-pill px-4">Change Password</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm fw-bold">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
