@model OnlineCoursesPlatform.Models.Course

@{
    ViewData["Title"] = "Confirm Enrollment";
}

<section class="page-hero mb-4">
    <span class="eyebrow mb-3"><i class="fa-solid fa-badge-check"></i>Student Checkout</span>
    <h1 class="section-title mb-2">Confirm your enrollment.</h1>
    <p class="section-subtitle mb-0">You are one step away from unlocking this course in your learning workspace.</p>
</section>

<section class="content-panel p-4 p-lg-5 text-center">
    <div class="mx-auto" style="max-width: 680px;">
        <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "/images/default-course.jpg" : Model.ImageUrl)" alt="@Model.Title" class="w-100 rounded-4 shadow-sm mb-4" style="max-height: 280px; object-fit: cover;" />
        <h2 class="fw-bold mb-2">@Model.Title</h2>
        <p class="text-muted mb-4">Once enrolled, this course appears in your learning dashboard and your progress starts from there.</p>

        <div class="metric-card p-4 mb-4">
            <div class="text-muted small text-uppercase mb-2">Price</div>
            <div class="metric-value">@Model.Currency.Symbol@Model.Price</div>
            <div class="text-muted mt-2">Currency: @Model.Currency.Name (@Model.Currency.Code)</div>
        </div>

        <form id="enrollForm">
            <input type="hidden" id="courseId" value="@Model.Id" />
            <div class="d-flex flex-wrap justify-content-center gap-2">
                <button id="confirmEnrollButton" type="button" onclick="confirmEnroll()" class="btn btn-app-primary">
                    Confirm & Start Learning
                </button>
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-app-secondary-dark">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function confirmEnroll() {
            const id = document.getElementById('courseId').value;
            const button = document.getElementById('confirmEnrollButton');

            button.disabled = true;
            button.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';

            try {
                const response = await fetch('/Enrollment/Enroll', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ courseId: parseInt(id) })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Something went wrong.');
                }

                await Swal.fire({
                    title: 'Enrollment complete',
                    text: 'Your course is now available in My Learning.',
                    icon: 'success',
                    confirmButtonText: data.firstLessonId ? 'Go to first lesson' : 'Open course page'
                });

                if (data.firstLessonId) {
                    window.location.href = '/Learning/Details/' + data.firstLessonId;
                } else {
                    window.location.href = '/Courses/Details/' + id;
                }
            } catch (error) {
                await Swal.fire('Enrollment failed', error.message, 'error');
                button.disabled = false;
                button.innerHTML = 'Confirm & Start Learning';
            }
        }
    </script>
}
