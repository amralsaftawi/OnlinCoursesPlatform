@model IEnumerable<OnlineCoursesPlatform.ViewModels.EnrolledCourseViewModel>

@{
    ViewData["Title"] = "My Learning";
}

<section class="page-hero mb-4">
    <span class="eyebrow mb-3"><i class="fa-solid fa-book-open-reader"></i>Student Workspace</span>
    <h1 class="section-title mb-2">Continue your enrolled courses.</h1>
    <p class="section-subtitle mb-0">Track progress and jump back into the learning experience with fewer distractions.</p>
</section>

<section class="row g-4">
    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="course-card h-100 overflow-hidden">
                    <img src="@(string.IsNullOrWhiteSpace((string?)item.ImageUrl) ? "/images/default-course.jpg" : item.ImageUrl)" class="w-100" style="height: 220px; object-fit: cover;" alt="@item.Title" />
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="soft-badge text-success"><i class="fa-solid fa-circle-check"></i>Enrolled</span>
                            <span class="text-muted small">@item.EnrolledAt.ToString("dd MMM yyyy")</span>
                        </div>
                        <h5 class="fw-bold mb-2">@item.Title</h5>
                        <div class="text-muted small mb-3">By @item.InstructorName</div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small class="text-muted">Progress</small>
                            <small class="fw-bold text-primary">@item.ProgressPercentage%</small>
                        </div>
                        <div class="small text-muted mb-2">
                            @if (item.TotalLessons > 0)
                            {
                                <span>@item.CompletedLessons of @item.TotalLessons lessons completed</span>
                            }
                            else
                            {
                                <span>Curriculum is being prepared.</span>
                            }
                        </div>
                        <div class="progress mb-4" style="height: 10px;">
                            <div class="progress-bar" role="progressbar" style="width: @item.ProgressPercentage%" aria-valuenow="@item.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        @if (item.ContinueLessonId != null)
                        {
                            <a asp-controller="Learning" asp-action="Details" asp-route-id="@item.ContinueLessonId" class="btn btn-app-primary w-100 mb-2">
                                @(item.IsCompleted ? "Review Course" : item.ProgressPercentage > 0 ? "Resume Learning" : "Start Course")
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-app-primary w-100 mb-2">Open Course</a>
                        }
                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-link text-decoration-none w-100">Course Details</a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="empty-state">
                <i class="fa-solid fa-book fs-1 text-muted mb-3"></i>
                <h4 class="fw-bold">No enrolled courses yet</h4>
                <p class="text-muted">Browse the catalog and enroll in your first course to begin learning.</p>
                <a asp-controller="Courses" asp-action="Index" class="btn btn-app-primary">Browse Courses</a>
            </div>
        </div>
    }
</section>
