@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "My Learning Journey";
}

<style>
    body {
        background-color: #f8f9fa;
    }
    .my-courses-header {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d3436 100%);
        padding: 60px 0;
        border-radius: 0 0 30px 30px;
        margin-top: -24px;
        color: white;
    }
    .course-card {
        border: none;
        border-radius: 20px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
        background: #fff;
    }
    .course-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }
    .progress {
        height: 8px;
        border-radius: 10px;
        background-color: #e9ecef;
    }
    .progress-bar {
        background: linear-gradient(90deg, #0d6efd, #0dcaf0);
    }
    .continue-btn {
        border-radius: 50px;
        font-weight: 600;
        padding: 8px 20px;
    }
    .empty-state {
        padding: 100px 0;
        text-align: center;
    }
</style>

<header class="my-courses-header text-center mb-5 shadow-sm">
    <div class="container">
        <h1 class="fw-bold display-5">My <span class="text-primary">Courses</span></h1>
        <p class="lead text-secondary">Track your progress and continue where you left off</p>
    </div>
</header>

<div class="container mb-5">
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card course-card shadow-sm h-100">
                        <div class="position-relative">
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                            <div class="position-absolute bottom-0 start-0 p-3 w-100" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                <span class="badge bg-primary rounded-pill">Enrolled</span>
                            </div>
                        </div>
                        
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold mb-3">@item.Title</h5>
                            
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted">Progress</small>
                                    <small class="fw-bold text-primary">@item.ProgressPercentage%</small>
                                </div>
                                <div class="progress mb-4">
                                    <div class="progress-bar" role="progressbar" style="width: @item.ProgressPercentage%" 
                                         aria-valuenow="@item.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                
                                @* اللينك ده هيودي الطالب لصفحة المحتوى (تأكد من اسم الـ Action عندك) *@
                                <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.CourseId" 
                                   class="btn btn-primary continue-btn w-100">
                                    <i class="fas fa-play me-2"></i> Continue Learning
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state animate__animated animate__fadeIn">
                    <div class="mb-4">
                        <i class="fas fa-book-reader display-1 text-muted opacity-25"></i>
                    </div>
                    <h3 class="fw-bold">No courses found!</h3>
                    <p class="text-muted">You haven't enrolled in any courses yet. Start your journey today.</p>
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-primary btn-lg px-5 mt-3 rounded-pill shadow">
                        Browse Courses
                    </a>
                </div>
            </div>
        }
    </div>
</div>