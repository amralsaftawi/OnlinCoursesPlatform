@{
    ViewData["Title"] = "Welcome to EduMaster";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d3436 100%);
        padding: 100px 0;
        border-radius: 0 0 50px 50px;
        margin-top: -24px; /* لدمجها مع النيفبار */
    }
    .feature-card {
        border: none;
        border-radius: 20px;
        transition: 0.3s;
        background: #fff;
    }
    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .course-badge {
        position: absolute;
        top: 15px;
        right: 15px;
    }
    .btn-hero {
        padding: 12px 35px;
        font-weight: 600;
        border-radius: 50px;
    }
</style>

<section class="hero-section text-white text-center mb-5 shadow">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="display-3 fw-bold mb-4">Master New Skills <span class="text-primary">Online</span></h1>
                <p class="lead mb-5 text-secondary">Join over 5,000+ students learning from the best industry experts. Start your journey today with our certified courses.</p>
                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-primary btn-hero shadow">Explore Courses</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-hero">Become an Instructor</a>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container mb-5 mt-n5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="p-4 shadow-sm bg-white rounded-4 border-bottom border-primary border-4">
                <h3 class="fw-bold mb-0">500+</h3>
                <small class="text-muted text-uppercase">Expert Instructors</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 shadow-sm bg-white rounded-4 border-bottom border-success border-4">
                <h3 class="fw-bold mb-0">12K+</h3>
                <small class="text-muted text-uppercase">Happy Students</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 shadow-sm bg-white rounded-4 border-bottom border-info border-4">
                <h3 class="fw-bold mb-0">150+</h3>
                <small class="text-muted text-uppercase">Online Courses</small>
            </div>
        </div>
    </div>
</div>

<section class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold">Top Categories</h2>
            <p class="text-muted">Browse courses by your favorite topics</p>
        </div>
        <a href="#" class="btn btn-link text-primary text-decoration-none fw-bold">View All <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="row g-4">
        @{
            var categories = new[] { 
                new { Name = "Development", Icon = "fa-code", Color = "text-primary" },
                new { Name = "Business", Icon = "fa-chart-line", Color = "text-success" },
                new { Name = "Design", Icon = "fa-pen-nib", Color = "text-warning" },
                new { Name = "Marketing", Icon = "fa-bullhorn", Color = "text-danger" }
            };
        }
        @foreach (var cat in categories)
        {
            <div class="col-md-3">
                <div class="card feature-card p-4 text-center shadow-sm">
                    <div class="h1 mb-3 @cat.Color">
                        <i class="fas @cat.Icon"></i>
                    </div>
                    <h5 class="fw-bold">@cat.Name</h5>
                </div>
            </div>
        }
    </div>
</section>

<section class="bg-light py-5 border-top border-bottom">
    <div class="container py-4">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 class="fw-bold mb-4">Why Choose <span class="text-primary">EduMaster</span>?</h2>
                <ul class="list-unstyled">
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-4"></i>
                        <span>Learn at your own pace with lifetime access.</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-4"></i>
                        <span>Get certificates recognized by top companies.</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-4"></i>
                        <span>Interactive coding exercises and quizzes.</span>
                    </li>
                </ul>
            </div>
            <div class="col-lg-6 text-center">
                <i class="fas fa-user-rocket display-1 text-primary opacity-25"></i>
            </div>
        </div>
    </div>
</section>