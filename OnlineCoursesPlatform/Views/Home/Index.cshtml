@using Microsoft.AspNetCore.Identity
@inject UserManager<OnlineCoursesPlatform.Models.User> userManager

@{
    ViewData["Title"] = "Welcome to EduMaster";
    var currentUser = User.Identity?.IsAuthenticated == true ? await userManager.GetUserAsync(User) : null;
    var currentRoles = currentUser != null ? await userManager.GetRolesAsync(currentUser) : Array.Empty<string>();
    var isAdmin = currentRoles.Contains("Admin");
    var isInstructor = currentRoles.Contains("Instructor");
    var isStudent = currentRoles.Contains("Student");
}

<section class="page-hero mb-5">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="eyebrow mb-3"><i class="fa-solid fa-sparkles"></i>Role-aware online learning</span>
            <h1 class="section-title">A cleaner platform for students, instructors, and admins.</h1>
            <p class="section-subtitle mb-4">
                Discover courses, manage teaching content, and review platform activity from focused workspaces built for each role.
            </p>

            <div class="d-flex flex-wrap gap-3">
                <a asp-controller="Courses" asp-action="Index" class="btn btn-app-primary">
                    <i class="fa-solid fa-compass me-2"></i>Explore Courses
                </a>

                @if (isAdmin)
                {
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-app-secondary-dark">
                        <i class="fa-solid fa-shield-halved me-2"></i>Admin Dashboard
                    </a>
                }
                else if (isInstructor)
                {
                    <a asp-controller="Instructor" asp-action="Index" class="btn btn-app-secondary-dark">
                        <i class="fa-solid fa-chalkboard-user me-2"></i>Instructor Hub
                    </a>
                }
                else if (isStudent)
                {
                    <a asp-controller="Enrollment" asp-action="GetMyEnrolledCourses" class="btn btn-app-secondary-dark">
                        <i class="fa-solid fa-book-open-reader me-2"></i>My Learning
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-app-secondary-dark">
                        <i class="fa-solid fa-user-plus me-2"></i>Create Free Account
                    </a>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="content-panel p-4 h-100">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <div class="soft-badge mb-2">Platform Snapshot</div>
                        <h5 class="mb-0 fw-bold">Built around focused access</h5>
                    </div>
                    <i class="fa-solid fa-layer-group fs-3 text-primary"></i>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <div class="metric-card p-3 h-100">
                            <div class="metric-value">12K+</div>
                            <div class="text-muted mt-2">Learners growing their skills</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="metric-card p-3 h-100">
                            <div class="metric-value">500+</div>
                            <div class="text-muted mt-2">Instructors sharing expertise</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="metric-card p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-bold">Role visibility</div>
                                    <div class="text-muted small">Students see learning paths, instructors see teaching tools, admins see review controls.</div>
                                </div>
                                <span class="soft-badge"><i class="fa-solid fa-lock"></i>Scoped UI</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="quick-link-card p-4 h-100">
                <div class="soft-badge mb-3">Students</div>
                <h4 class="fw-bold">Stay on track</h4>
                <p class="text-muted">Browse courses, enroll quickly, and continue learning from one place.</p>
                @if (isStudent && !isAdmin && !isInstructor)
                {
                    <a asp-controller="Enrollment" asp-action="GetMyEnrolledCourses" class="btn btn-sm btn-app-primary mt-2">Open My Learning</a>
                }
            </div>
        </div>
        <div class="col-md-4">
            <div class="quick-link-card p-4 h-100">
                <div class="soft-badge mb-3">Instructors</div>
                <h4 class="fw-bold">Teach with clarity</h4>
                <p class="text-muted">Create courses, manage curriculum, and monitor your teaching performance.</p>
                @if (isInstructor && !isAdmin)
                {
                    <a asp-controller="Instructor" asp-action="MyCourses" class="btn btn-sm btn-app-primary mt-2">Manage Courses</a>
                }
            </div>
        </div>
        <div class="col-md-4">
            <div class="quick-link-card p-4 h-100">
                <div class="soft-badge mb-3">Admins</div>
                <h4 class="fw-bold">Review with control</h4>
                <p class="text-muted">Access the dashboard, approve courses, and manage platform users responsibly.</p>
                @if (isAdmin)
                {
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-app-primary mt-2">Open Dashboard</a>
                }
            </div>
        </div>
    </div>
</section>

<section class="content-panel p-4 p-lg-5">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="eyebrow mb-3"><i class="fa-solid fa-check"></i>Why EduMaster</span>
            <h2 class="fw-bold mb-3">Less clutter, better journeys.</h2>
            <p class="text-muted mb-0">
                The platform now guides each role toward the actions that matter most, reducing confusion and keeping the experience cleaner across the app.
            </p>
        </div>
        <div class="col-lg-5">
            <div class="row g-3">
                <div class="col-6">
                    <div class="metric-card p-3 h-100">
                        <div class="fw-bold mb-2">Role-specific navigation</div>
                        <small class="text-muted">Only relevant sections are shown.</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="metric-card p-3 h-100">
                        <div class="fw-bold mb-2">Unified UI</div>
                        <small class="text-muted">Cards, forms, tables, and CTAs now follow one system.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
