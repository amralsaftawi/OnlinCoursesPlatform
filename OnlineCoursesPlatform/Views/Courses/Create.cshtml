@model OnlineCoursesPlatform.ViewModels.CreateCourseViewModel

@{
    ViewData["Title"] = "Create Course";
    var hasCategories = Model.CategoriesList.Any();
    var hasCurrencies = Model.CurrenciesList.Any();
}

<section class="page-hero mb-4">
    <span class="eyebrow mb-3"><i class="fa-solid fa-circle-plus"></i>Instructor Only</span>
    <h1 class="section-title mb-2">Create the course shell, then build the curriculum.</h1>
    <p class="section-subtitle mb-0">Start with the core course info, then jump straight into sections and lessons while admins keep control of approval.</p>
</section>

<section class="content-panel p-4 p-lg-5">
    @if (!hasCategories || !hasCurrencies)
    {
        <div class="alert alert-warning alert-app">
            Course creation needs admin-managed reference data first.
            @if (!hasCategories)
            {
                <span> No categories are available yet.</span>
            }
            @if (!hasCurrencies)
            {
                <span> No currencies are available yet.</span>
            }
        </div>
    }

    <form asp-action="Create" method="post" enctype="multipart/form-data" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">Course Title</label>
                    <input asp-for="Title" class="form-control" placeholder="Build a production-ready ASP.NET course" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="6" placeholder="Describe who this course is for, what learners will build, and the outcomes they can expect."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SelectedTagIds" class="form-label fw-semibold">Tags</label>
                    <select asp-for="SelectedTagIds" class="form-select" asp-items="Model.TagsList" multiple style="min-height: 140px;"></select>
                    <small class="text-muted">Choose only the tags that genuinely describe the course. Tags are managed centrally by admins.</small>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label fw-semibold">Course Image</label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="metric-card p-4 mb-4">
                    <h5 class="fw-bold mb-3">Publishing Logic</h5>
                    <ul class="text-muted mb-0 ps-3">
                        <li class="mb-2">New courses are always submitted as `Pending`.</li>
                        <li class="mb-2">Only admins can approve or reject publication.</li>
                        <li>Students see only approved courses in the public catalog.</li>
                    </ul>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="Model.CategoriesList" disabled="@(!hasCategories)">
                        <option value="">Select Category</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CurrencyId" class="form-label fw-semibold">Currency</label>
                    <select asp-for="CurrencyId" class="form-select" asp-items="Model.CurrenciesList" disabled="@(!hasCurrencies)">
                        <option value="">Select Currency</option>
                    </select>
                    <span asp-validation-for="CurrencyId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-semibold">Price</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Level" class="form-label fw-semibold">Level</label>
                    <select asp-for="Level" class="form-select" asp-items="Html.GetEnumSelectList<OnlineCoursesPlatform.Models.Enums.CourseLevel>()"></select>
                    <span asp-validation-for="Level" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Language" class="form-label fw-semibold">Language</label>
                    <input asp-for="Language" class="form-control" />
                    <span asp-validation-for="Language" class="text-danger small"></span>
                </div>

                <div class="metric-card p-3 mb-4">
                    <div class="fw-bold mb-2">Duration Handling</div>
                    <div class="text-muted small">You do not enter total course duration here. It is recalculated automatically from lesson durations as you build the curriculum.</div>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-app-primary" disabled="@(!hasCategories || !hasCurrencies)">Save And Build Curriculum</button>
            <a asp-action="Index" class="btn btn-app-secondary-dark">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
