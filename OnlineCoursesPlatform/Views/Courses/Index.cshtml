@model IEnumerable<OnlineCoursesPlatform.ViewModels.CourseListViewModel>

@{
    ViewData["Title"] = "All Courses";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<style>
    /* --- Your Existing Premium UI Styles --- */
    .hero-section { background: linear-gradient(135deg, #4e54c8, #8f94fb); color: white; border-radius: 12px; padding: 3rem 2rem; box-shadow: 0 10px 30px rgba(78, 84, 200, 0.2); margin-bottom: 2rem; }
    .hover-lift { transition: transform 0.3s ease, box-shadow 0.3s ease; border: none; }
    .hover-lift:hover { transform: translateY(-8px); box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1) !important; }
    .card-img-wrapper { overflow: hidden; border-top-left-radius: calc(0.25rem - 1px); border-top-right-radius: calc(0.25rem - 1px); position: relative; }
    .card-img-wrapper img { transition: transform 0.5s ease; }
    .hover-lift:hover .card-img-wrapper img { transform: scale(1.05); }
    .price-tag { font-weight: 800; color: #2e7d32; font-size: 1.15rem; background: rgba(46, 125, 50, 0.1); padding: 5px 12px; border-radius: 20px; }
    .pagination .page-link { border-radius: 50% !important; margin: 0 4px; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: #4e54c8; font-weight: 600; border: none; }
    .pagination .page-item.active .page-link { background-color: #4e54c8; color: white; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .filter-card { border-radius: 15px; border: none; background: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
</style>

<div class="container mt-4 mb-5">
    
    @* --- Hero Header --- *@
    <div class="hero-section d-flex flex-column flex-md-row align-items-center justify-content-between">
        <div>
            <h1 class="fw-bold mb-2">Explore Our Best Courses 🎓</h1>
            <p class="lead mb-0 text-white-50">Advance your career and learn from top experts.</p>
        </div>
        
        @* Show Create Button only to Instructors *@
        @if (User.IsInRole("Instructor"))
        {
            <div class="mt-4 mt-md-0">
                <a asp-action="Create" class="btn btn-light btn-lg fw-bold shadow-sm rounded-pill px-4">
                <i class="bi bi-plus-circle-fill me-2 text-primary"></i> Create Course
                </a>
            </div>
        }
    </div>

    @* --- Advanced Multi-Filter Form --- *@
    <div class="filter-card p-4 mb-5">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Keyword</label>
                <input type="text" name="searchTerm" class="form-control rounded-pill border-light bg-light shadow-none" 
                       placeholder="Search courses..." value="@ViewBag.CurrentSearch">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Category</label>
                <select name="categoryId" asp-items="ViewBag.Categories" class="form-select rounded-pill border-light bg-light shadow-none">
                    <option value="">All Categories</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Tags</label>
                <div class="dropdown">
                    <button class="btn btn-light rounded-pill border-light w-100 text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown">
                        <span class="small text-muted">Select Tags</span>
                        <i class="bi bi-chevron-down small"></i>
                    </button>
                    <div class="dropdown-menu p-3 shadow border-0 rounded-3" style="min-width: 250px;">
                        @foreach (var tag in (IEnumerable<OnlineCoursesPlatform.Models.Tag>)ViewBag.Tags)
    {
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="checkbox" name="selectedTags" value="@tag.Id" 
                                       id="tag_@tag.Id" @(ViewBag.SelectedTags.Contains(tag.Id) ? "checked" : "")>
                                <label class="form-check-label small" for="tag_@tag.Id">@tag.Name</label>
        </div>
    }
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary rounded-pill w-100 fw-bold shadow-sm">Apply Filters</button>
            </div>
        </form>
        </div>
    }

    @* --- Courses Grid --- *@
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                    <h3 class="fw-bold text-secondary mb-3">No courses found 😔</h3>
                <a asp-action="Index" class="btn btn-link text-primary">Reset all filters</a>
            </div>
        }
        else
        {
            foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4 d-flex align-items-stretch">
                    <div class="card w-100 shadow-sm hover-lift">
                        <div class="card-img-wrapper">
                            <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "/images/default-course.jpg" : course.ImageUrl)" class="card-img-top w-100" style="height: 220px; object-fit: cover;">
                            <span class="badge bg-dark position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill">@course.CategoryName</span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark line-clamp-2">@course.Title</h5>
                            <p class="card-text text-muted small line-clamp-2 mb-4 flex-grow-1">@course.Description</p>
                            <div class="d-flex align-items-center border-top pt-3">
                                <img src="/images/profiles/@(string.IsNullOrEmpty(course.InstructorProfilePicture) ? "default-avatar.png" : course.InstructorProfilePicture)" class="rounded-circle me-2" width="35" height="35" style="object-fit: cover;">
                                <div class="lh-sm">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">Instructor</small>
                                    <small class="fw-bold text-dark">@course.InstructorName</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="price-tag">@course.CurrencySymbol@course.Price</span>
                            <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-primary rounded-pill px-4 fw-semibold">View</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @* --- Pagination --- *@
    @if (totalPages > 1)
    {
        <nav class="mt-5 d-flex justify-content-center">
            <ul class="pagination shadow-sm rounded-pill bg-white p-2">

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        @{
                            var routeData = new Dictionary<string, string> {
                                { "page", i.ToString() },
                                { "searchTerm", ViewBag.CurrentSearch },
                                { "categoryId", ViewBag.SelectedCategory?.ToString() }
                            };
                        }
                        <a class="page-link" asp-action="Index" asp-all-route-data="routeData">@i</a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>