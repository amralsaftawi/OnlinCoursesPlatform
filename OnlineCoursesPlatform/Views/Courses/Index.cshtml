@model IEnumerable<OnlineCoursesPlatform.ViewModels.CourseListViewModel>

@{
    ViewData["Title"] = "All Courses";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<style>
    /* --- Premium UI Enhancements --- */
    .hero-section {
        background: linear-gradient(135deg, #4e54c8, #8f94fb);
        color: white;
        border-radius: 12px;
        padding: 3rem 2rem;
        box-shadow: 0 10px 30px rgba(78, 84, 200, 0.2);
        margin-bottom: 2.5rem;
    }
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
    }
    .hover-lift:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1) !important;
    }
    .card-img-wrapper {
        overflow: hidden;
        border-top-left-radius: calc(0.25rem - 1px);
        border-top-right-radius: calc(0.25rem - 1px);
        position: relative;
    }
    .card-img-wrapper img {
        transition: transform 0.5s ease;
    }
    .hover-lift:hover .card-img-wrapper img {
        transform: scale(1.05);
    }
    .price-tag {
        font-weight: 800;
        color: #2e7d32; /* Rich Green */
        font-size: 1.15rem;
        background: rgba(46, 125, 50, 0.1);
        padding: 5px 12px;
        border-radius: 20px;
    }
    .pagination .page-link {
        border-radius: 50% !important;
        margin: 0 4px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4e54c8;
        font-weight: 600;
        border: none;
        transition: background-color 0.2s, color 0.2s;
    }
    .pagination .page-item.active .page-link {
        background-color: #4e54c8;
        color: white;
        box-shadow: 0 4px 10px rgba(78, 84, 200, 0.3);
    }
    .pagination .page-item.disabled .page-link {
        color: #adb5bd;
    }
    .empty-state {
        padding: 4rem 2rem;
        background: #f8f9fa;
        border-radius: 12px;
        border: 2px dashed #dee2e6;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<div class="container mt-4 mb-5">
    
    @* --- 1. Hero Header --- *@
    <div class="hero-section d-flex flex-column flex-md-row align-items-center justify-content-between">
        <div>
            <h1 class="fw-bold mb-2">Explore Our Best Courses 🎓</h1>
            <p class="lead mb-0 text-white-50">Discover new skills, advance your career, and learn from top experts.</p>
        </div>
        
        @* Show Create Button only to Instructors *@
        @if (User.IsInRole("Instructor"))
        {
            <div class="mt-4 mt-md-0">
                <a asp-action="Create" class="btn btn-light btn-lg fw-bold shadow-sm rounded-pill px-4">
                    <i class="bi bi-plus-circle-fill me-2 text-primary"></i> Create New Course
                </a>
            </div>
        }
    </div>

    @* Server Errors *@
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-lg rounded-3 position-fixed top-0 end-0 m-4" style="z-index: 1055;" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @* Success Messages (Floating Toast Style) *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-lg rounded-3 position-fixed top-0 end-0 m-4" style="z-index: 1055; border-left: 5px solid #198754;" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5 text-success align-middle"></i> 
            <span class="fw-bold align-middle">@TempData["Success"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* --- 2. Courses Grid --- *@
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center mt-3">
                <div class="empty-state">
                    <h3 class="fw-bold text-secondary mb-3">No courses found 😔</h3>
                    <p class="text-muted">Stay tuned! Our instructors are working hard to bring you new content.</p>
                </div>
            </div>
        }
        else
        {
            foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4 d-flex align-items-stretch">
                    <div class="card w-100 shadow-sm hover-lift d-flex flex-column">
                        
                        <div class="card-img-wrapper position-relative">
                            <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "/images/default-course.jpg" : course.ImageUrl)" 
                                 class="card-img-top w-100" 
                                 alt="@course.Title" 
                                 style="height: 220px; object-fit: cover;">
                            
                            <span class="badge bg-dark position-absolute top-0 start-0 m-3 px-3 py-2 shadow-sm rounded-pill">
                                @course.CategoryName
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark lh-base mb-3 line-clamp-2" title="@course.Title">
                                @course.Title
                            </h5>
                            
                            <p class="card-text text-muted small line-clamp-2 mb-4 flex-grow-1">
                                @course.Description
                            </p>

                            <div class="d-flex align-items-center mt-auto border-top pt-3">
                                <img src="~/images/profiles/@(string.IsNullOrEmpty(course.InstructorProfilePicture) ? "default-avatar.png" : course.InstructorProfilePicture)" 
                                     class="rounded-circle shadow-sm me-2" 
                                     width="35" height="35" 
                                     style="object-fit: cover;"
                                     alt="Instructor">
                                <div class="lh-sm">
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">Instructor</small>
                                    <small class="fw-bold text-dark">@course.InstructorName</small>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center rounded-bottom">
                            <span class="price-tag">
                                @course.CurrencySymbol@course.Price
                            </span>

                            <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                                View
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @* --- 3. Pagination Controls --- *@
    @if (totalPages > 1)
    {
        <nav aria-label="Course pagination" class="mt-5 d-flex justify-content-center">
            <ul class="pagination shadow-sm rounded-pill bg-white p-2">

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>