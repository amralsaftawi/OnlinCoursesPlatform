@model IEnumerable<OnlineCoursesPlatform.ViewModels.CourseListViewModel>
@using System.Globalization

@functions {
    private static string ResolveProfileImage(string? profilePicture)
    {
        if (string.IsNullOrWhiteSpace(profilePicture))
        {
            return "/images/profiles/default-avatar.png";
        }

        return profilePicture.StartsWith("/")
            ? profilePicture
            : $"/images/profiles/{profilePicture}";
    }

    private static string BuildPageUrl(int pageNumber, string? currentSearch, object? selectedCategory, List<int> selectedTags)
    {
        var parts = new List<string> { $"page={pageNumber}" };

        if (!string.IsNullOrWhiteSpace(currentSearch))
        {
            parts.Add($"searchTerm={Uri.EscapeDataString(currentSearch)}");
        }

        if (selectedCategory != null && !string.IsNullOrWhiteSpace(selectedCategory.ToString()))
        {
            parts.Add($"categoryId={selectedCategory}");
        }

        foreach (var tagId in selectedTags)
        {
            parts.Add($"selectedTags={tagId}");
        }

        return $"/Courses?{string.Join("&", parts)}";
    }
}

@{
    ViewData["Title"] = "All Courses";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalCount = ViewBag.TotalCount ?? 0;
    bool hasFilters = ViewBag.HasFilters ?? false;
    var selectedTags = ViewBag.SelectedTags as List<int> ?? new List<int>();
    string? currentSearch = ViewBag.CurrentSearch as string;
}

<style>
    .browse-layout {
        display: grid;
        grid-template-columns: minmax(260px, 320px) 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    .browse-sidebar {
        position: sticky;
        top: 96px;
    }

    .browse-card {
        overflow: hidden;
    }

    .browse-card-image {
        height: 220px;
        width: 100%;
        object-fit: cover;
    }

    .browse-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .browse-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .browse-card-summary {
        min-height: 3rem;
    }

    @@media (max-width: 991.98px) {
        .browse-layout {
            grid-template-columns: 1fr;
        }

        .browse-sidebar {
            position: static;
        }
    }
</style>

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <span class="eyebrow mb-3"><i class="fa-solid fa-book-open"></i>Course Discovery</span>
            <h1 class="section-title mb-2">Browse courses with clearer signals.</h1>
            <p class="section-subtitle mb-0">Find the right instructor, compare categories faster, and jump into course details without digging around.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <span class="soft-badge"><i class="fa-solid fa-layer-group"></i>@totalCount result@(totalCount == 1 ? string.Empty : "s")</span>
            @if (User.IsInRole("Instructor"))
            {
                <a asp-action="Create" class="btn btn-app-primary">
                    <i class="fa-solid fa-plus me-2"></i>Create Course
                </a>
            }
        </div>
    </div>
</section>

<section class="browse-layout">
    <aside class="browse-sidebar">
        <section class="content-panel p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">Filter Courses</h5>
                @if (hasFilters)
                {
                    <a asp-action="Index" class="small text-decoration-none">Clear All</a>
                }
            </div>

            <form asp-action="Index" method="get" class="d-flex flex-column gap-3">
                <div>
                    <label class="form-label fw-semibold">Keyword</label>
                    <input type="text" name="searchTerm" class="form-control" placeholder="Title or topic" value="@currentSearch" />
                </div>

                <div>
                    <label class="form-label fw-semibold">Category</label>
                    <select name="categoryId" asp-items="ViewBag.Categories" class="form-select">
                        <option value="">All Categories</option>
                    </select>
                </div>

                <div>
                    <label class="form-label fw-semibold">Tags</label>
                    <div class="d-flex flex-column gap-2 p-3 rounded-4 border bg-white">
                        @foreach (var tag in (IEnumerable<OnlineCoursesPlatform.Models.Tag>)ViewBag.Tags)
                        {
                            <label class="form-check d-flex align-items-center gap-2 mb-0">
                                <input class="form-check-input" type="checkbox" name="selectedTags" value="@tag.Id" @(selectedTags.Contains(tag.Id) ? "checked" : null) />
                                <span class="form-check-label">@tag.Name</span>
                            </label>
                        }
                    </div>
                </div>

                <button type="submit" class="btn btn-app-primary w-100">Apply Filters</button>
            </form>
        </section>
    </aside>

    <div class="d-flex flex-column gap-4">
        <section class="content-panel p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="fw-bold mb-1">Explore The Catalog</h5>
                    <p class="text-muted mb-0">Each card now highlights the instructor and price more clearly, and the whole card opens the course.</p>
                </div>
                @if (hasFilters)
                {
                    <div class="browse-meta">
                        @if (!string.IsNullOrWhiteSpace(currentSearch))
                        {
                            <span class="soft-badge">Search: @currentSearch</span>
                        }
                        @if ((ViewBag.SelectedCategory as int?) > 0)
                        {
                            <span class="soft-badge">Category Filter On</span>
                        }
                        @if (selectedTags.Any())
                        {
                            <span class="soft-badge">@selectedTags.Count tag filter@(selectedTags.Count == 1 ? string.Empty : "s")</span>
                        }
                    </div>
                }
            </div>
        </section>

        <section>
            <div class="row g-4">
                @if (!Model.Any())
                {
                    <div class="col-12">
                        <div class="empty-state">
                            <i class="fa-regular fa-folder-open fs-1 text-muted mb-3"></i>
                            <h4 class="fw-bold">No courses matched your filters</h4>
                            <p class="text-muted">Try a broader search or reset the current filters.</p>
                            <a asp-action="Index" class="btn btn-app-primary mt-2">Reset Filters</a>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var course in Model)
                    {
                        <div class="col-md-6 col-xl-4">
                            <article class="course-card browse-card h-100 position-relative" onclick="window.location='@Url.Action("Details", "Courses", new { id = course.Id })'" role="link" tabindex="0" onkeydown="if(event.key==='Enter' || event.key===' '){ window.location='@Url.Action("Details", "Courses", new { id = course.Id })'; }" style="cursor:pointer;">
                                <div class="position-relative">
                                    <img src="@(string.IsNullOrWhiteSpace(course.ImageUrl) ? "/images/default-course.jpg" : course.ImageUrl)" class="browse-card-image" alt="@course.Title" />
                                    <span class="soft-badge position-absolute top-0 start-0 m-3">@course.CategoryName</span>
                                </div>

                                <div class="p-4 d-flex flex-column h-100">
                                    <div class="browse-card-header mb-3">
                                        <a asp-controller="Instructor" asp-action="Profile" asp-route-id="@course.InstructorId" class="d-flex align-items-center gap-2 text-decoration-none position-relative" onclick="event.stopPropagation();">
                                            <img src="@ResolveProfileImage(course.InstructorProfilePicture)" class="rounded-circle border" width="44" height="44" style="object-fit: cover;" alt="@course.InstructorName" />
                                            <div>
                                                <div class="small text-muted">Instructor</div>
                                                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(course.InstructorName) ? "Unknown Instructor" : course.InstructorName)</div>
                                            </div>
                                        </a>
                                        <div class="text-end">
                                            <div class="small text-muted text-uppercase">Price</div>
                                            <div class="fw-bold fs-5 text-primary">@course.CurrencySymbol@course.Price.ToString("0.##", CultureInfo.InvariantCulture)</div>
                                        </div>
                                    </div>

                                    <h5 class="fw-bold line-clamp-2 mb-2">@course.Title</h5>
                                    <p class="text-muted browse-card-summary line-clamp-2 mb-4">@course.Description</p>

                                    <div class="mt-auto d-flex justify-content-between align-items-center gap-3">
                                        <span class="small text-muted">Open the full syllabus and enrollment details.</span>
                                        <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-app-primary" onclick="event.stopPropagation();">Open Course</a>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                }
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-5 d-flex justify-content-center">
                    <ul class="pagination bg-white rounded-pill p-2 shadow-sm">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@(currentPage == 1 ? "#" : BuildPageUrl(currentPage - 1, currentSearch, ViewBag.SelectedCategory, selectedTags))">&laquo;</a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" href="@BuildPageUrl(i, currentSearch, ViewBag.SelectedCategory, selectedTags)">@i</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" href="@(currentPage == totalPages ? "#" : BuildPageUrl(currentPage + 1, currentSearch, ViewBag.SelectedCategory, selectedTags))">&raquo;</a>
                        </li>
                    </ul>
                </nav>
            }
        </section>
    </div>
</section>
