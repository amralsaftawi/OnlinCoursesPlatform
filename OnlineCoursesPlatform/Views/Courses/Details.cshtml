@model OnlineCoursesPlatform.ViewModels.CourseDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<style>
    /* Dark Hero Banner */
    .course-hero {
        background-color: #1c1d1f;
        color: white;
        padding: 3rem 0;
        margin-top: -1.5rem; /* Pull up to touch the navbar */
    }

    .hero-breadcrumb {
        font-size: 0.85rem;
        color: #c0c4fc;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .hero-title {
        font-weight: 700;
        font-size: 2.2rem;
        margin-bottom: 10px;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        font-weight: 400;
        color: #d1d7dc;
        margin-bottom: 20px;
    }

    .hero-meta {
        font-size: 0.9rem;
        margin-bottom: 10px;
    }

    .rating-stars {
        color: #f69c08;
    }

    /* Floating Enrollment Card */
    .enroll-card {
        background: #fff;
        border: 1px solid #d1d7dc;
        box-shadow: 0 4px 8px rgba(0,0,0,0.08), 0 0 1px rgba(0,0,0,0.1);
        border-radius: 4px;
        position: sticky;
        top: 20px;
        z-index: 10;
        overflow: hidden;
    }

    .enroll-card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .enroll-price-huge {
        font-size: 2.2rem;
        font-weight: 700;
        color: #1c1d1f;
        margin-bottom: 1rem;
    }

    /* Section Styling */
    .content-section {
        margin-top: 2.5rem;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        color: #1c1d1f;
    }

    /* Syllabus Accordion */
    .accordion-button {
        background-color: #f7f9fa;
        font-weight: 600;
        color: #1c1d1f;
        padding: 1rem 1.25rem;
    }

    .accordion-button:not(.collapsed) {
        background-color: #f7f9fa;
        color: #1c1d1f;
        box-shadow: inset 0 -1px 0 rgba(0,0,0,.125);
    }

    .lesson-item {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid #e1e3e8;
        font-size: 0.95rem;
    }

    .lesson-item:last-child {
        border-bottom: none;
    }

    .lesson-title {
        color: #1c1d1f;
        display: flex;
        align-items: center;
    }

    .lesson-icon {
        color: #5624d0;
        margin-right: 10px;
    }
    
    .lesson-meta {
        color: #6a6f73;
        font-size: 0.85rem;
    }

    /* Tags / Skills */
    .skill-badge {
        background-color: #f7f9fa;
        color: #1c1d1f;
        border: 1px solid #d1d7dc;
        border-radius: 50px;
        padding: 8px 16px;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-block;
        margin-right: 8px;
        margin-bottom: 8px;
    }

    /* Instructor */
    .instructor-bio {
        margin-top: 1rem;
    }

    .instructor-name {
        color: #5624d0;
        font-weight: 700;
        text-decoration: underline;
        font-size: 1.25rem;
    }

    /* Reviews */
    .review-item {
        border-top: 1px solid #d1d7dc;
        padding: 1.5rem 0;
    }
    .review-avatar {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 50%;
        background-color: #1c1d1f;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.2rem;
    }
</style>

<!-- 1. Dark Hero Banner -->
<div class="course-hero">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="hero-breadcrumb">
                    Development > @Model.CategoryName > @Model.Language
                </div>
                
                <h1 class="hero-title">@Model.Title</h1>
                <p class="hero-subtitle">@Model.Description</p>
                
                <div class="hero-meta d-flex align-items-center flex-wrap">
                    @* Rating Component *@
                    <span class="text-warning fw-bold me-2" style="font-size: 1.1rem;">@Model.AverageRating.ToString("0.0")</span>
                    <div class="rating-stars me-2" style="font-size: 0.9rem;">
                        @for(int i = 0; i < Math.Floor(Model.AverageRating); i++) { <i class="bi bi-star-fill"></i> }
                        @if(Model.AverageRating % 1 != 0) { <i class="bi bi-star-half"></i> }
                        @for(int i = 0; i < (5 - Math.Ceiling(Model.AverageRating)); i++) { <i class="bi bi-star"></i> }
                    </div>
                    <a href="#reviews" class="text-info text-decoration-underline me-3">(@Model.ReviewCount ratings)</a>
                    
                    <span class="me-3"><i class="bi bi-person-fill"></i> @(Model.ReviewCount * 142) students</span>
                </div>
                
                <div class="hero-meta mt-2">
                    <span class="me-4">Created by <a href="#instructor" class="text-info text-decoration-underline">@Model.InstructorName</a></span>
                    <span class="me-4"><i class="bi bi-patch-exclamation-fill me-1"></i>Last updated 11/2025</span>
                    <span class="me-4"><i class="bi bi-globe me-1"></i>@Model.Language</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container my-5">
    <div class="row">
        <!-- Main Content Area -->
        <div class="col-lg-8 pe-lg-5">
            
            <!-- 2. What you'll learn (Tags) -->
            @if (Model.Tags.Any())
            {
                <div class="content-section p-4 border rounded" style="background-color: #f7f9fa; border-color: #d1d7dc;">
                    <h2 class="section-title mb-4">What you'll learn</h2>
                    <div>
                        @foreach(var tag in Model.Tags)
                        {
                            <span class="skill-badge"><i class="bi bi-check2 text-success me-2 fw-bold"></i>@tag</span>
                        }
                    </div>
                </div>
            }

            <!-- 3. Course Content (Syllabus Accordion) -->
            <div class="content-section">
                <h2 class="section-title">Course content</h2>
                <div class="d-flex justify-content-between mb-2 text-muted small pb-2">
                    <span>@Model.SectionCount sections • @Model.TotalLessons lectures • @Model.TotalDuration h total length</span>
                </div>

                @if (!Model.Sections.Any())
                {
                    <div class="alert alert-light border text-center p-4">
                        <i class="bi bi-journal-x fs-1 text-muted d-block mb-2"></i>
                        The instructor hasn't uploaded the syllabus yet.
                    </div>
                }
                else
                {
                    <div class="accordion border rounded" id="syllabusAccordion">
                        @foreach (var courseSection in Model.Sections)
                        {
                            string headingId = $"heading{courseSection.Id}";
                            string collapseId = $"collapse{courseSection.Id}";

                            <div class="accordion-item border-0 border-bottom">
                                <h2 class="accordion-header" id="@headingId">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                        <span class="fw-bold flex-grow-1">@courseSection.Title</span>
                                        <span class="text-muted small fw-normal ms-3">@courseSection.Lessons.Count lectures</span>
                                    </button>
                                </h2>
                                <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId">
                                    <div class="accordion-body p-0 px-4">
                                        
                                        @foreach (var lesson in courseSection.Lessons)
                                        {
                                            <div class="lesson-item">
                                                <div class="lesson-title">
                                                    <i class="bi bi-play-circle-fill lesson-icon"></i>
                                                    @lesson.Title
                                                </div>
                                                <div class="lesson-meta">
                                                    @if(lesson.IsFree) {
                                                        <span class="badge bg-success me-2">Preview</span>
                                                    }
                                                    @lesson.Duration min
                                                </div>
                                            </div>
                                        }

                                        @if(!courseSection.Lessons.Any())
                                        {
                                            <div class="p-3 text-muted small text-center">No lessons in this section yet.</div>
                                        }

                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- 4. Instructor -->
            <div class="content-section" id="instructor">
                <h2 class="section-title">Instructor</h2>
                <div class="d-flex align-items-center mb-3">
                    <img src="~/images/profiles/@(string.IsNullOrEmpty(Model.InstructorProfilePicture) ? "default-avatar.png" : Model.InstructorProfilePicture)" 
                         class="rounded-circle me-4 shadow-sm" 
                         width="110" height="110" 
                         style="object-fit: cover;" alt="@Model.InstructorName">
                    <div>
                        <a href="#" class="instructor-name">@Model.InstructorName</a>
                        <div class="text-muted small">Course Instructor</div>
                    </div>
                </div>
            </div>

            <!-- 5. Reviews -->
            <div class="content-section mb-5" id="reviews">
                <h2 class="section-title"><i class="bi bi-star-fill text-warning me-2"></i> @Model.AverageRating.ToString("0.0") course rating • @Model.ReviewCount ratings</h2>
                
                <div class="row mt-4">
                    @if (!Model.Reviews.Any())
                    {
                        <div class="col-12 text-center text-muted p-4">
                            No reviews yet. Be the first to review!
                        </div>
                    }

                    @foreach (var review in Model.Reviews)
                    {
                        <div class="col-md-6">
                            <div class="review-item">
                                <div class="d-flex mb-3">
                                    @if(!string.IsNullOrEmpty(review.StudentProfilePicture) && review.StudentProfilePicture != "default-avatar.png")
                                    {
                                        <img src="~/images/profiles/@review.StudentProfilePicture" class="review-avatar me-3">
                                    }
                                    else
                                    {
                                        <div class="review-avatar me-3">@review.StudentName.Substring(0, 1).ToUpper()</div>
                                    }
                                    
                                    <div>
                                        <div class="fw-bold">@review.StudentName</div>
                                        <div class="d-flex align-items-center">
                                            <div class="rating-stars me-2" style="font-size: 0.8rem;">
                                                @for(int i = 0; i < review.Rating; i++) { <i class="bi bi-star-fill"></i> }
                                                @for(int i = 0; i < (5 - review.Rating); i++) { <i class="bi bi-star"></i> }
                                            </div>
                                            <span class="text-muted small">@review.CreatedAt.ToString("MMM yyyy")</span>
                                        </div>
                                    </div>
                                </div>
                                <p class="text-dark m-0" style="font-size: 0.95rem;">"@review.Comment"</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- Right Sidebar (Floating Enrollment Card) -->
        <div class="col-lg-4 d-none d-lg-block">
            <div class="enroll-card">
                <!-- Course Image on Top -->
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default-course.jpg" : Model.ImageUrl)" class="enroll-card-img" alt="@Model.Title">
                
                <div class="p-4">
                    <div class="enroll-price-huge">@Model.CurrencySymbol@Model.Price</div>
                    
                    <button class="btn btn-danger w-100 py-3 fw-bold mb-2 text-white" style="background-color: #a435f0; border: none; font-size: 1.1rem;">
                        Enroll Now
                    </button>
                    
                    <div class="text-center text-muted small mb-4">30-Day Money-Back Guarantee</div>
                    
                    <h6 class="fw-bold mb-3">This course includes:</h6>
                    <ul class="list-unstyled text-dark small" style="line-height: 2;">
                        <li><i class="bi bi-display me-3 text-center" style="width:20px;"></i> @Model.TotalDuration hours on-demand video</li>
                        <li><i class="bi bi-file-earmark-text me-3 text-center" style="width:20px;"></i> 12 articles</li>
                        <li><i class="bi bi-download me-3 text-center" style="width:20px;"></i> 45 downloadable resources</li>
                        <li><i class="bi bi-phone me-3 text-center" style="width:20px;"></i> Access on mobile and TV</li>
                        <li><i class="bi bi-infinity me-3 text-center" style="width:20px;"></i> Full lifetime access</li>
                        <li><i class="bi bi-trophy me-3 text-center" style="width:20px;"></i> Certificate of completion</li>
                    </ul>

                    <div class="d-flex justify-content-between mt-4 pb-2 border-bottom">
                        <a href="#" class="text-dark fw-bold text-decoration-underline" style="font-size: 0.9rem;">Share</a>
                        <a href="#" class="text-dark fw-bold text-decoration-underline" style="font-size: 0.9rem;">Gift this course</a>
                        <a href="#" class="text-dark fw-bold text-decoration-underline" style="font-size: 0.9rem;">Apply Coupon</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
