@using OnlineCoursesPlatform.Dtos
@model AdminDashboardDto

<h2 class="mb-4">Admin Dashboard</h2>

<div class="row">

    <!-- Users -->
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3 shadow">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <h2>@Model.UsersCount</h2>
            </div>
        </div>
    </div>

    <!-- Courses -->
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3 shadow">
            <div class="card-body">
                <h5 class="card-title">Courses</h5>
                <h2>@Model.CoursesCount</h2>
            </div>
        </div>
    </div>

    <!-- Pending -->
    <div class="col-md-4">
        <div class="card text-white bg-warning mb-3 shadow">
            <div class="card-body">
                <h5 class="card-title">Pending Courses</h5>
                <h2>@Model.PendingCoursesCount</h2>
            </div>
        </div>
    </div>

</div>

<hr />

<div class="mt-4">
    <a asp-action="Users" class="btn btn-outline-primary me-2">
        Manage Users
    </a>

    <a asp-action="Courses" class="btn btn-outline-success">
        Review Courses
    </a>
</div>