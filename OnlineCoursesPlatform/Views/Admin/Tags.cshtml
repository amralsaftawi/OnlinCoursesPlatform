@model OnlineCoursesPlatform.ViewModels.AdminTagsViewModel

@{
    ViewData["Title"] = "Manage Tags";
}

<section class="page-hero mb-4">
    <span class="eyebrow mb-3"><i class="fa-solid fa-tags"></i>Admin Only</span>
    <h1 class="section-title mb-2">Manage course tags.</h1>
    <p class="section-subtitle mb-0">Tags should stay clean, reusable, and centralized so instructors classify courses consistently.</p>
</section>

<div class="row g-4">
    <div class="col-lg-4">
        <section class="content-panel p-4">
            <h5 class="fw-bold mb-3">Add Tag</h5>
            <form asp-action="Tags" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="NewTagName" class="form-label fw-semibold">Tag Name</label>
                    <input asp-for="NewTagName" class="form-control" placeholder="backend" />
                    <span asp-validation-for="NewTagName" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-app-primary w-100">Add Tag</button>
            </form>
        </section>
    </div>
    <div class="col-lg-8">
        <section class="table-panel p-4">
            <div class="table-responsive">
                <table class="table app-table align-middle">
                    <thead>
                        <tr>
                            <th>Tag</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tag in Model.Tags)
                        {
                            <tr>
                                <td>
                                    <form asp-action="UpdateTag" method="post" class="d-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@tag.Id" />
                                        <input type="text" name="name" value="@tag.Name" class="form-control" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill">Save</button>
                                    </form>
                                </td>
                                <td class="text-end">
                                    <form asp-action="DeleteTag" method="post" onsubmit="return confirm('Delete this tag?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@tag.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
