@model OnlineCoursesPlatform.ViewModels.LearningViewModel
@using OnlineCoursesPlatform.Models.Enums

@functions {
    private static bool IsYouTubeUrl(string? url)
    {
        return !string.IsNullOrWhiteSpace(url)
            && (url.Contains("youtube.com", StringComparison.OrdinalIgnoreCase)
                || url.Contains("youtu.be", StringComparison.OrdinalIgnoreCase));
    }

    private static bool IsPdfUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        var normalizedUrl = url.Split('?')[0].Split('#')[0];
        return normalizedUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDirectVideoUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        var normalizedUrl = url.Split('?')[0].Split('#')[0];
        return normalizedUrl.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".webm", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".ogg", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".mov", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".m4v", StringComparison.OrdinalIgnoreCase)
            || url.Contains("/videos/", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetYouTubeEmbedUrl(string url)
    {
        if (url.Contains("youtu.be/", StringComparison.OrdinalIgnoreCase))
        {
            var id = url.Split("youtu.be/").LastOrDefault()?.Split('?').FirstOrDefault();
            return $"https://www.youtube.com/embed/{id}";
        }

        var watchIndex = url.IndexOf("v=", StringComparison.OrdinalIgnoreCase);
        if (watchIndex >= 0)
        {
            var id = url[(watchIndex + 2)..].Split('&').FirstOrDefault();
            return $"https://www.youtube.com/embed/{id}";
        }

        return url;
    }
}

@{
    ViewData["Title"] = $"Learning: {Model.CurrentLesson.Title}";
    var content = Model.CurrentLesson.ContentUrl ?? string.Empty;
    var orderedLessons = Model.CourseLessons
        .OrderBy(lesson => lesson.SectionOrderIndex)
        .ThenBy(lesson => lesson.OrderIndex)
        .ToList();
    var currentIndex = orderedLessons.FindIndex(lesson => lesson.Id == Model.CurrentLesson.Id);
    var previousLesson = currentIndex > 0 ? orderedLessons[currentIndex - 1] : null;
    var nextLesson = currentIndex >= 0 && currentIndex < orderedLessons.Count - 1 ? orderedLessons[currentIndex + 1] : null;
    var isTrackingEnabled = Model.CanTrackProgress;
}

<section class="page-hero mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <span class="eyebrow mb-3"><i class="fa-solid fa-book-open-reader"></i>Learning Workspace</span>
            <h1 class="section-title mb-2">@Model.CurrentLesson.Title</h1>
            <p class="section-subtitle mb-0">@Model.CourseTitle</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-app-secondary-dark">Course Details</a>
            @if (isTrackingEnabled)
            {
                <a asp-controller="Enrollment" asp-action="GetMyEnrolledCourses" class="btn btn-app-secondary-dark">My Learning</a>
            }
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-8">
        <section class="content-panel p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                <div>
                    <div class="small text-muted text-uppercase mb-1">Current Lesson</div>
                    <div class="fw-semibold">@((currentIndex + 1).ToString()) / @orderedLessons.Count</div>
                    <div class="small text-muted">@(string.IsNullOrWhiteSpace(Model.CurrentLesson.SectionTitle) ? "Course Content" : Model.CurrentLesson.SectionTitle)</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (previousLesson != null)
                    {
                        <a asp-action="Details" asp-route-id="@previousLesson.Id" class="btn btn-outline-dark rounded-pill">Previous Lesson</a>
                    }
                    @if (nextLesson != null)
                    {
                        <a asp-action="Details" asp-route-id="@nextLesson.Id" class="btn btn-outline-dark rounded-pill">Next Lesson</a>
                    }
                </div>
            </div>

            @if (Model.CurrentLesson.Type == LessonType.Video)
            {
                <div class="mb-3">
                    <h4 class="fw-bold mb-2">Video Lesson</h4>
                    <p class="text-muted mb-0">Play the lesson here and continue to the next lecture when you finish.</p>
                </div>

                if (IsYouTubeUrl(content))
                {
                    <div class="ratio ratio-16x9 rounded-4 overflow-hidden bg-dark">
                        <iframe src="@GetYouTubeEmbedUrl(content)?rel=0&modestbranding=1" title="@Model.CurrentLesson.Title" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen class="border-0"></iframe>
                    </div>
                }
                else if (IsDirectVideoUrl(content))
                {
                    <div class="ratio ratio-16x9 rounded-4 overflow-hidden bg-dark">
                        <video controls playsinline preload="metadata" class="w-100 h-100">
                            <source src="@content" type="video/mp4" />
                            <source src="@content" type="video/webm" />
                            <source src="@content" type="video/ogg" />
                            <source src="@content" />
                        </video>
                    </div>
                }
                else
                {
                    <div class="ratio ratio-16x9 rounded-4 overflow-hidden bg-dark">
                        <iframe src="@content" title="@Model.CurrentLesson.Title" allow="autoplay; fullscreen" allowfullscreen class="border-0"></iframe>
                    </div>
                }
            }
            else if (Model.CurrentLesson.Type == LessonType.PDF)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                    <div>
                        <h4 class="fw-bold mb-1">PDF Lesson</h4>
                        <p class="text-muted mb-0">Review the attached file inside the platform or open it separately.</p>
                    </div>
                    <a href="@content" target="_blank" class="btn btn-app-primary">Open PDF</a>
                </div>

                @if (IsPdfUrl(content))
                {
                    <iframe src="@content" class="w-100 rounded-4 border" style="min-height: 760px;" title="@Model.CurrentLesson.Title"></iframe>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-file-pdf fs-1 text-muted mb-3"></i>
                        <h4 class="fw-bold">PDF preview is not available</h4>
                        <p class="text-muted">The stored lesson file is not a direct PDF link, so open it in a new tab.</p>
                    </div>
                }
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                    <div>
                        <h4 class="fw-bold mb-1">Article PDF</h4>
                        <p class="text-muted mb-0">Open the attached article document here or in a new tab.</p>
                    </div>

                    @if (IsPdfUrl(content))
                    {
                        <a href="@content" target="_blank" class="btn btn-app-primary">Open PDF</a>
                    }
                </div>

                @if (string.IsNullOrWhiteSpace(content))
                {
                    <div class="alert alert-warning">No content available.</div>
                }
                else if (IsPdfUrl(content))
                {
                    <iframe src="@content" class="w-100 rounded-4 border" style="min-height: 760px;" title="@Model.CurrentLesson.Title"></iframe>
                }
                else if (Uri.IsWellFormedUriString(content, UriKind.Absolute) || content.StartsWith("/"))
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-file-pdf fs-1 text-muted mb-3"></i>
                        <h4 class="fw-bold">This article needs a PDF file</h4>
                        <p class="text-muted mb-3">The current stored file is not a direct PDF link, so it cannot be previewed here.</p>
                        <a href="@content" target="_blank" class="btn btn-app-primary">Open File</a>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary rounded-4 border-0 mb-3">
                        This is legacy article text saved before the PDF-only article flow. It still displays here for compatibility.
                    </div>
                    <article class="metric-card p-4" style="line-height: 1.95;">
                        @Html.Raw(Html.Encode(content)
                            .Replace("\r\n", "<br /><br />")
                            .Replace("\n", "<br /><br />"))
                    </article>
                }
            }
        </section>

        <section class="content-panel p-4">
            @if (Model.IsOwnerPreview)
            {
                <div class="alert alert-info rounded-3 border-0 mb-4">
                    You are previewing your own course as the instructor. Playback and reading work here, but progress remains student-only.
                </div>
            }

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                <div>
                    <h4 class="fw-bold mb-1">Lesson Actions</h4>
                    <p class="text-muted mb-0">Duration: @Model.CurrentLesson.Duration min &bull; @Model.CompletedLessons/@Model.TotalLessons lessons completed</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (!Model.CanTrackProgress)
                    {
                        <button class="btn btn-outline-secondary rounded-pill" disabled>@(Model.IsOwnerPreview ? "Owner Preview" : "Preview Mode")</button>
                    }
                    else if (Model.IsCompleted)
                    {
                        <button class="btn btn-outline-success rounded-pill" disabled>Already Completed</button>
                    }
                    else
                    {
                        <button id="markCompleteBtn" class="btn btn-app-primary" onclick="markCompleteAndNext(@Model.CurrentLesson.Id)">Mark as Completed</button>
                    }
                </div>
            </div>
        </section>
    </div>

    <div class="col-lg-4">
        <section class="table-panel p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">@(isTrackingEnabled ? "Progress" : "Preview Mode")</h5>
                <span class="fw-semibold text-primary">@(isTrackingEnabled ? $"{Model.ProgressPercentage}%" : "Instructor/Admin")</span>
            </div>
            <div class="progress mb-3" style="height: 10px;">
                <div class="progress-bar" role="progressbar" style="width: @(isTrackingEnabled ? $"{Model.ProgressPercentage}%" : "100%")" aria-valuenow="@(isTrackingEnabled ? Model.ProgressPercentage : 100)" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
            <div class="small fw-semibold mb-2">@Model.CompletedLessons / @Model.TotalLessons lessons completed</div>
            <div class="small text-muted">
                @(isTrackingEnabled
                    ? "Track lesson completion and return to this course from your My Learning dashboard."
                    : "You are previewing the lesson content only. Progress tracking stays reserved for enrolled students.")
            </div>
        </section>

        <section class="table-panel p-4">
            <h5 class="fw-bold mb-3">Course Lessons</h5>
            <div class="d-flex flex-column gap-2">
                @foreach (var lesson in orderedLessons)
                {
                    var iconClass = lesson.Type == LessonType.Video ? "fa-circle-play" : lesson.Type == LessonType.PDF ? "fa-file-pdf" : "fa-file-lines";
                    var isCurrent = lesson.Id == Model.CurrentLesson.Id;

                    <a asp-action="Details" asp-route-id="@lesson.Id" class="metric-card p-3 text-decoration-none @(isCurrent ? "border-primary" : "")">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="d-flex gap-3">
                                <i class="fa-solid @iconClass text-primary mt-1"></i>
                                <div>
                                    <div class="fw-semibold text-dark">@lesson.Title</div>
                                    <div class="small text-muted">@lesson.SectionTitle &bull; @lesson.Duration min</div>
                                </div>
                            </div>
                            <span class="soft-badge">@(isCurrent ? "Now" : lesson.Type.ToString())</span>
                        </div>
                    </a>
                }
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function markCompleteAndNext(lessonId) {
            const btn = document.getElementById('markCompleteBtn');
            if (!btn) {
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

            try {
                const response = await fetch(`/Learning/MarkAsComplete/${lessonId}`, { method: 'POST' });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || 'Could not save progress.');
                }

                if (data.nextLessonId) {
                    window.location.href = `/Learning/Details/${data.nextLessonId}`;
                    return;
                }

                await Swal.fire('Great work', 'You completed the final lesson in this course.', 'success');
                window.location.reload();
            } catch (error) {
                await Swal.fire('Error', error.message, 'error');
                btn.disabled = false;
                btn.innerHTML = 'Mark as Completed';
            }
        }
    </script>
}
