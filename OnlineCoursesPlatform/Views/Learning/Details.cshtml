@model OnlineCoursesPlatform.ViewModels.LearningViewModel
@using OnlineCoursesPlatform.Models.Enums

@functions {
    private static bool IsYouTubeUrl(string? url)
    {
        return !string.IsNullOrWhiteSpace(url)
            && (url.Contains("youtube.com", StringComparison.OrdinalIgnoreCase)
                || url.Contains("youtu.be", StringComparison.OrdinalIgnoreCase));
    }

    private static bool IsPdfUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        var normalizedUrl = url.Split('?')[0].Split('#')[0];
        return normalizedUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDirectVideoUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        var normalizedUrl = url.Split('?')[0].Split('#')[0];
        return normalizedUrl.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".webm", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".ogg", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".mov", StringComparison.OrdinalIgnoreCase)
            || normalizedUrl.EndsWith(".m4v", StringComparison.OrdinalIgnoreCase)
            || url.Contains("/videos/", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetYouTubeEmbedUrl(string url)
    {
        if (url.Contains("youtu.be/", StringComparison.OrdinalIgnoreCase))
        {
            var id = url.Split("youtu.be/").LastOrDefault()?.Split('?').FirstOrDefault();
            return $"https://www.youtube.com/embed/{id}";
        }

        var watchIndex = url.IndexOf("v=", StringComparison.OrdinalIgnoreCase);
        if (watchIndex >= 0)
        {
            var id = url[(watchIndex + 2)..].Split('&').FirstOrDefault();
            return $"https://www.youtube.com/embed/{id}";
        }

        return url;
    }

    private static (string Label, string Icon) DescribeLessonType(LessonType type)
    {
        return type switch
        {
            LessonType.Video => ("Video", "fa-circle-play"),
            LessonType.PDF => ("PDF", "fa-file-pdf"),
            LessonType.Article => ("Article", "fa-file-lines"),
            LessonType.Quiz => ("Quiz", "fa-circle-question"),
            _ => ("Lesson", "fa-book-open")
        };
    }
}

@{
    ViewData["Title"] = $"Learning: {Model.CurrentLesson.Title}";
    var content = Model.CurrentLesson.ContentUrl ?? string.Empty;
    var orderedLessons = Model.CourseLessons
        .OrderBy(lesson => lesson.SectionOrderIndex)
        .ThenBy(lesson => lesson.OrderIndex)
        .ToList();
    var currentIndex = orderedLessons.FindIndex(lesson => lesson.Id == Model.CurrentLesson.Id);
    var previousLesson = currentIndex > 0 ? orderedLessons[currentIndex - 1] : null;
    var nextLesson = currentIndex >= 0 && currentIndex < orderedLessons.Count - 1 ? orderedLessons[currentIndex + 1] : null;
    var isTrackingEnabled = Model.CanTrackProgress;
    var currentLessonMeta = DescribeLessonType(Model.CurrentLesson.Type);
    var isQuizLesson = Model.CurrentLesson.Type == LessonType.Quiz;
    var hasTextArticle = !string.IsNullOrWhiteSpace(Model.CurrentLesson.ArticleContent);
}

<section class="page-hero mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <span class="eyebrow mb-3"><i class="fa-solid fa-book-open-reader"></i>Learning Workspace</span>
            <h1 class="section-title mb-2">@Model.CurrentLesson.Title</h1>
            <p class="section-subtitle mb-2">@Model.CourseTitle</p>
            <div class="d-flex flex-wrap gap-2">
                <span class="soft-badge"><i class="fa-solid @currentLessonMeta.Icon"></i>@currentLessonMeta.Label</span>
                <span class="soft-badge"><i class="fa-regular fa-clock"></i>@Model.CurrentLesson.Duration min</span>
                @if (Model.CurrentLesson.IsFree)
                {
                    <span class="soft-badge"><i class="fa-solid fa-lock-open"></i>Free Preview</span>
                }
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-app-secondary-dark">Course Details</a>
            @if (isTrackingEnabled)
            {
                <a asp-controller="Enrollment" asp-action="GetMyEnrolledCourses" class="btn btn-app-secondary-dark">My Learning</a>
            }
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-xl-8">
        <section class="content-panel p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                <div>
                    <div class="small text-muted text-uppercase mb-1">Current Lesson</div>
                    <div class="fw-semibold">@(currentIndex + 1) / @orderedLessons.Count</div>
                    <div class="small text-muted">@(string.IsNullOrWhiteSpace(Model.CurrentLesson.SectionTitle) ? "Course Content" : Model.CurrentLesson.SectionTitle)</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (previousLesson != null)
                    {
                        <a asp-action="Details" asp-route-id="@previousLesson.Id" class="btn btn-outline-dark rounded-pill">Previous</a>
                    }
                    @if (nextLesson != null)
                    {
                        <a asp-action="Details" asp-route-id="@nextLesson.Id" class="btn btn-outline-dark rounded-pill">Next</a>
                    }
                </div>
            </div>

            @if (Model.CurrentLesson.Type == LessonType.Video)
            {
                <div class="mb-3">
                    <h4 class="fw-bold mb-2">Video Lesson</h4>
                    <p class="text-muted mb-0">Watch the lecture here, then move directly to the next lesson when you finish.</p>
                </div>

                @if (IsYouTubeUrl(content))
                {
                    <div class="ratio ratio-16x9 rounded-4 overflow-hidden bg-dark shadow-sm">
                        <iframe src="@GetYouTubeEmbedUrl(content)?rel=0&modestbranding=1" title="@Model.CurrentLesson.Title" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen class="border-0"></iframe>
                    </div>
                }
                else if (IsDirectVideoUrl(content))
                {
                    <div class="ratio ratio-16x9 rounded-4 overflow-hidden bg-dark shadow-sm">
                        <video controls playsinline preload="metadata" class="w-100 h-100">
                            <source src="@content" type="video/mp4" />
                            <source src="@content" type="video/webm" />
                            <source src="@content" type="video/ogg" />
                            <source src="@content" />
                        </video>
                    </div>
                }
                else
                {
                    <div class="ratio ratio-16x9 rounded-4 overflow-hidden bg-dark shadow-sm">
                        <iframe src="@content" title="@Model.CurrentLesson.Title" allow="autoplay; fullscreen" allowfullscreen class="border-0"></iframe>
                    </div>
                }
            }
            else if (Model.CurrentLesson.Type == LessonType.PDF)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                    <div>
                        <h4 class="fw-bold mb-1">PDF Lesson</h4>
                        <p class="text-muted mb-0">Read the material inside the platform or open it in a dedicated tab.</p>
                    </div>
                    <a href="@content" target="_blank" class="btn btn-app-primary">Open PDF</a>
                </div>

                @if (IsPdfUrl(content))
                {
                    <iframe src="@content" class="w-100 rounded-4 border" style="min-height: 760px;" title="@Model.CurrentLesson.Title"></iframe>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-file-pdf fs-1 text-muted mb-3"></i>
                        <h4 class="fw-bold">PDF preview is not available</h4>
                        <p class="text-muted mb-3">The stored file is not a direct PDF source, so open it in a new tab.</p>
                        <a href="@content" target="_blank" class="btn btn-app-primary">Open File</a>
                    </div>
                }
            }
            else if (Model.CurrentLesson.Type == LessonType.Article)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                    <div>
                        <h4 class="fw-bold mb-1">Article Lesson</h4>
                        <p class="text-muted mb-0">Read the text directly here without leaving the learning flow.</p>
                    </div>
                </div>

                @if (hasTextArticle)
                {
                    <article class="metric-card p-4" style="line-height: 1.9;">
                        @Html.Raw(Html.Encode(Model.CurrentLesson.ArticleContent)
                            .Replace("\r\n", "<br /><br />")
                            .Replace("\n", "<br /><br />"))
                    </article>
                }
                else if (!string.IsNullOrWhiteSpace(content) && (Uri.IsWellFormedUriString(content, UriKind.Absolute) || content.StartsWith("/")))
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-file-lines fs-1 text-muted mb-3"></i>
                        <h4 class="fw-bold">Legacy article content detected</h4>
                        <p class="text-muted mb-3">This article was created before the TXT article flow. Open the stored file directly if you still need it.</p>
                        <a href="@content" target="_blank" class="btn btn-app-primary">Open Stored File</a>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning rounded-4 border-0">No readable article text is available for this lesson.</div>
                }
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                    <div>
                        <h4 class="fw-bold mb-1">Quiz Lesson</h4>
                        <p class="text-muted mb-0">Answer the quiz below to complete this lesson and keep your progress moving.</p>
                    </div>
                    <span class="soft-badge">@Model.CurrentLesson.Quiz?.QuestionType</span>
                </div>

                @if (Model.CurrentLesson.Quiz == null)
                {
                    <div class="alert alert-warning rounded-4 border-0">This quiz could not be loaded correctly.</div>
                }
                else
                {
                    <div class="metric-card p-4">
                        <div class="small text-muted text-uppercase mb-2">Question</div>
                        <h5 class="fw-bold mb-4">@Model.CurrentLesson.Quiz.Prompt</h5>

                        <form id="quizForm" class="d-flex flex-column gap-3">
                            @if (Model.CurrentLesson.Quiz.QuestionType == QuizQuestionType.TrueFalse || Model.CurrentLesson.Quiz.QuestionType == QuizQuestionType.MultipleChoice)
                            {
                                foreach (var option in Model.CurrentLesson.Quiz.Options)
                                {
                                    <label class="border rounded-4 p-3 d-flex align-items-start gap-3">
                                        <input class="form-check-input mt-1" type="radio" name="quizAnswer" value="@option" />
                                        <span>@option</span>
                                    </label>
                                }
                            }
                            else
                            {
                                <div>
                                    <label class="form-label fw-semibold">Your Written Answer</label>
                                    <textarea class="form-control" id="writtenQuizAnswer" rows="5" placeholder="Write your answer here..."></textarea>
                                </div>
                            }

                            <div id="quizFeedback" class="d-none alert rounded-4 border-0 mb-0"></div>
                        </form>
                    </div>
                }
            }
        </section>

        <section class="content-panel p-4">
            @if (Model.IsOwnerPreview)
            {
                <div class="alert alert-info rounded-3 border-0 mb-4">
                    You are previewing your own course as the instructor. The player and reading experience work here, but progress remains student-only.
                </div>
            }

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                <div>
                    <h4 class="fw-bold mb-1">Lesson Actions</h4>
                    <p class="text-muted mb-0">@Model.CompletedLessons/@Model.TotalLessons lessons completed &bull; Progress @Model.ProgressPercentage%</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (!Model.CanTrackProgress)
                    {
                        <button class="btn btn-outline-secondary rounded-pill" disabled>@(Model.IsOwnerPreview ? "Owner Preview" : "Preview Mode")</button>
                    }
                    else if (Model.IsCompleted)
                    {
                        <button class="btn btn-outline-success rounded-pill" disabled>Already Completed</button>
                    }
                    else if (isQuizLesson)
                    {
                        <button id="submitQuizBtn" class="btn btn-app-primary" @(Model.CurrentLesson.Quiz == null ? "disabled" : null)>Submit Quiz</button>
                    }
                    else
                    {
                        <button id="markCompleteBtn" class="btn btn-app-primary">Mark as Completed</button>
                    }
                </div>
            </div>
        </section>
    </div>

    <div class="col-xl-4">
        <section class="table-panel p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">@(isTrackingEnabled ? "Progress" : "Preview Mode")</h5>
                <span class="fw-semibold text-primary">@(isTrackingEnabled ? $"{Model.ProgressPercentage}%" : "Preview")</span>
            </div>
            <div class="progress mb-3" style="height: 10px;">
                <div class="progress-bar" role="progressbar" style="width: @(isTrackingEnabled ? $"{Model.ProgressPercentage}%" : "100%")" aria-valuenow="@(isTrackingEnabled ? Model.ProgressPercentage : 100)" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
            <div class="small fw-semibold mb-2">@Model.CompletedLessons / @Model.TotalLessons lessons completed</div>
            <div class="small text-muted">
                @(isTrackingEnabled
                    ? "Complete each lesson here and return anytime from your My Learning dashboard."
                    : "You can preview the learning flow here, but tracked progress stays reserved for enrolled students.")
            </div>
        </section>

        <section class="table-panel p-4">
            <h5 class="fw-bold mb-3">Course Lessons</h5>
            <div class="d-flex flex-column gap-2">
                @foreach (var lesson in orderedLessons)
                {
                    var lessonMeta = DescribeLessonType(lesson.Type);
                    var isCurrent = lesson.Id == Model.CurrentLesson.Id;

                    <a asp-action="Details" asp-route-id="@lesson.Id" class="metric-card p-3 text-decoration-none @(isCurrent ? "border-primary" : "")">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="d-flex gap-3">
                                <i class="fa-solid @lessonMeta.Icon text-primary mt-1"></i>
                                <div>
                                    <div class="fw-semibold text-dark">@lesson.Title</div>
                                    <div class="small text-muted">@lesson.SectionTitle &bull; @lesson.Duration min</div>
                                </div>
                            </div>
                            <span class="soft-badge">@(isCurrent ? "Now" : lessonMeta.Label)</span>
                        </div>
                    </a>
                }
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function completeLesson(url, loadingLabel, button) {
            if (!button) {
                return;
            }

            button.disabled = true;
            const originalHtml = button.innerHTML;
            button.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>${loadingLabel}`;

            try {
                const response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || 'Could not save progress.');
                }

                if (data.message) {
                    await Swal.fire('Success', data.message, 'success');
                }

                if (data.nextLessonId) {
                    window.location.href = `/Learning/Details/${data.nextLessonId}`;
                    return;
                }

                window.location.reload();
            } catch (error) {
                await Swal.fire('Error', error.message, 'error');
                button.disabled = false;
                button.innerHTML = originalHtml;
            }
        }

        const markCompleteBtn = document.getElementById('markCompleteBtn');
        if (markCompleteBtn) {
            markCompleteBtn.addEventListener('click', function () {
                completeLesson(`/Learning/MarkAsComplete/@Model.CurrentLesson.Id`, 'Saving...', markCompleteBtn);
            });
        }

        const submitQuizBtn = document.getElementById('submitQuizBtn');
        const quizFeedback = document.getElementById('quizFeedback');

        if (submitQuizBtn) {
            submitQuizBtn.addEventListener('click', async function () {
                let answer = '';
                const selectedOption = document.querySelector('input[name="quizAnswer"]:checked');
                const writtenAnswer = document.getElementById('writtenQuizAnswer');

                if (selectedOption) {
                    answer = selectedOption.value;
                } else if (writtenAnswer) {
                    answer = writtenAnswer.value.trim();
                }

                if (!answer) {
                    quizFeedback.className = 'alert alert-warning rounded-4 border-0 mb-0';
                    quizFeedback.textContent = 'Please answer the quiz before submitting.';
                    quizFeedback.classList.remove('d-none');
                    return;
                }

                submitQuizBtn.disabled = true;
                submitQuizBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';

                try {
                    const response = await fetch(`/Learning/SubmitQuiz/@Model.CurrentLesson.Id`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ answer })
                    });

                    const data = await response.json();
                    if (!response.ok || !data.success) {
                        throw new Error(data.message || 'Could not submit the quiz.');
                    }

                    quizFeedback.className = 'alert alert-success rounded-4 border-0 mb-0';
                    quizFeedback.textContent = data.message || 'Quiz submitted successfully.';
                    quizFeedback.classList.remove('d-none');

                    if (data.nextLessonId) {
                        setTimeout(() => {
                            window.location.href = `/Learning/Details/${data.nextLessonId}`;
                        }, 900);
                        return;
                    }

                    setTimeout(() => window.location.reload(), 900);
                } catch (error) {
                    quizFeedback.className = 'alert alert-danger rounded-4 border-0 mb-0';
                    quizFeedback.textContent = error.message;
                    quizFeedback.classList.remove('d-none');
                    submitQuizBtn.disabled = false;
                    submitQuizBtn.innerHTML = 'Submit Quiz';
                }
            });
        }
    </script>
}
